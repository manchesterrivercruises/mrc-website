# .env.example
# Copy this file to .env and fill in real values.
# Never commit .env — only this .env.example file is checked into version control.

# ─── Ventrata OCTO API ────────────────────────────────────────────────────────
# Read-only connection key for product and availability data.
# WARNING: This is the TEST key for EdinExplore (Ventrata's fictional test supplier).
# It will not return real MRC products. Replace with the live MRC OCTO key before launch.
# To get the live MRC key: Ventrata dashboard -> Settings -> API -> OCTO connection key
# Used ONLY in Netlify Functions — never in client-side code.
VENTRATA_OCTO_KEY=a79eba1c-e336-4fc4-82c7-2290bc99d2ea

# ─── Ventrata Checkout Widget ─────────────────────────────────────────────────
# Safe to use in the DOM (confirmed by Ventrata).
VENTRATA_CHECKOUT_API_KEY=29b8b50a-26b8-4dae-bf0e-995708d2f372

# ─── Widget Environment ───────────────────────────────────────────────────────
# Set to "test" during development, "live" before launch.
VENTRATA_ENV=test

# ─── Core Products ────────────────────────────────────────────────────────────
VENTRATA_PRODUCT_CITY_RIVER_TOUR=ef45d8bd-529c-4dae-9c35-cd1b8e4e0a75
