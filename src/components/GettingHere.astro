---
import SectionHeading from './SectionHeading.astro';
import { site } from '../data/site';

// Fixed "Getting Here" template — used on every bookable product page. All products depart
// from the same boarding point (Millennium Footbridge, Salford Quays), so this is static.
const placeholderTile =
  'flex items-center justify-center rounded-card border border-dashed border-black/15 bg-panel text-sm text-subtle';
---

<section aria-labelledby="getting-here">
  <SectionHeading id="getting-here">Getting here</SectionHeading>
  <div class="mt-8 grid gap-8 sm:grid-cols-2">
    <div class="space-y-6 text-body">
      <div>
        <h3 class="font-semibold text-ink">Where to board</h3>
        <p class="mt-1 leading-relaxed">
          {site.addressDisplay} — beside MediaCityUK,
          a short walk from The Lowry and the Imperial War Museum North.
        </p>
        <a
          href="https://www.google.com/maps/search/?api=1&query=Millennium+Footbridge+Salford+Quays+M50+3RB"
          class="mt-2 inline-block font-medium text-primary hover:underline"
          rel="noopener"
          target="_blank"
        >
          Open in Google Maps
        </a>
      </div>
      <div>
        <h3 class="font-semibold text-ink">By tram</h3>
        <p class="mt-1 leading-relaxed">Take the Metrolink to MediaCityUK; the boarding point is a few minutes' walk.</p>
      </div>
      <div>
        <h3 class="font-semibold text-ink">Parking &amp; taxis</h3>
        <p class="mt-1 leading-relaxed">Quayside car parks are nearby. Taxi drop-off is available close to the footbridge. (Details TBC.)</p>
      </div>
    </div>
    {/* Contained image: on the 2-column layout (sm+) cap the height and top-align so it can't
        outgrow the text column; mobile keeps the natural 4/3. */}
    <img
      src="/images/gallery/our-boats/boats-moored-at-millennium-footbridge-card.webp"
      alt="Manchester River Cruises boats moored at the Salford Quays boarding point beside the Millennium Footbridge and The Lowry"
      width="800"
      height="600"
      loading="lazy"
      data-img-fallback
      class="aspect-[4/3] w-full self-start rounded-card object-cover ring-1 ring-black/5 sm:max-h-80"
    />
  </div>
</section>
