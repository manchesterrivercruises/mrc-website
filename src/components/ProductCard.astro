---
// Compact product card (image, name, description, link) — used for the cross-sell.
// Accepts a class / extra attributes so the parent can attach rotator behaviour.
// The ENTIRE card is a single wrapping <a> so the whole surface is the hit area.
interface Props {
  name: string;
  desc: string;
  href: string;
  linkText?: string;
  imageLabel?: string;
  class?: string;
  [key: string]: unknown;
}
const {
  name,
  desc,
  href,
  linkText = 'Find out more',
  imageLabel = 'Image (TBC)',
  class: className = '',
  ...rest
} = Astro.props;
const external = href.startsWith('http');
---

<article class={className} {...rest}>
  <a
    href={href}
    target={external ? '_blank' : undefined}
    rel={external ? 'noopener' : undefined}
    aria-label={name}
    class="group block rounded-card focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
  >
    <div class="flex aspect-[16/9] items-center justify-center rounded-card bg-panel text-xs text-subtle">
      {imageLabel}
    </div>
    <strong class="mt-3 block text-ink">{name}</strong>
    <p class="mt-1 text-sm leading-relaxed text-subtle">{desc}</p>
    <span class="mt-2 inline-block text-sm font-medium text-primary group-hover:underline">
      {linkText}
    </span>
  </a>
</article>
