---
// Compact product card (image, name, description, link) — used for the cross-sell.
// Accepts a class / extra attributes so the parent can attach rotator behaviour.
interface Props {
  name: string;
  desc: string;
  href: string;
  linkText?: string;
  imageLabel?: string;
  class?: string;
  [key: string]: unknown;
}
const {
  name,
  desc,
  href,
  linkText = 'Find out more',
  imageLabel = 'Image (TBC)',
  class: className = '',
  ...rest
} = Astro.props;
const external = href.startsWith('http');
---

<article class={className} {...rest}>
  <div class="flex aspect-[16/9] items-center justify-center rounded-card bg-panel text-xs text-subtle">
    {imageLabel}
  </div>
  <strong class="mt-3 block text-ink">{name}</strong>
  <p class="mt-1 text-sm leading-relaxed text-subtle">{desc}</p>
  <a
    href={href}
    target={external ? '_blank' : undefined}
    rel={external ? 'noopener' : undefined}
    class="mt-2 inline-block text-sm font-medium text-primary hover:underline"
  >
    {linkText}
  </a>
</article>
