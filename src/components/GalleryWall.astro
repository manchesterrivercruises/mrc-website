---
import type { Album } from '../lib/gallery';
import { CATEGORY_LABELS } from '../lib/gallery';
import GalleryAlbumCard from './GalleryAlbumCard.astro';

// Gallery hub wall: CSS-columns masonry of album covers + a category filter (the same
// accessible peer-checked pill pattern as What's On). All cards stay in the HTML for
// crawlers; the client script only toggles visibility.
interface Props {
  albums: Album[];
}
const { albums } = Astro.props;

// Only show filters for categories that actually have albums, in a stable order.
const CATEGORY_ORDER: Album['data']['category'][] = [
  'live-music',
  'dj-night',
  'family',
  'seasonal',
  'boats',
  'route',
  'private-hire',
];
const present = CATEGORY_ORDER.filter((c) => albums.some((a) => a.data.category === c));
const filters = [{ value: 'all', label: 'All' }, ...present.map((c) => ({ value: c, label: CATEGORY_LABELS[c] }))];

const pillClass =
  'inline-block rounded-full border border-black/15 px-4 py-1.5 text-sm font-medium text-body transition hover:border-primary/50 peer-checked:border-primary peer-checked:bg-primary peer-checked:text-white peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-primary';
---

<div class="gallery-wall">
  {/* Category filter */}
  <fieldset class="m-0 flex flex-wrap gap-2 border-0 p-0">
    <legend class="sr-only">Filter galleries by category</legend>
    {
      filters.map((f, i) => (
        <label class="cursor-pointer">
          <input type="radio" name="gw-cat" value={f.value} checked={i === 0} class="peer sr-only" />
          <span class={pillClass}>{f.label}</span>
        </label>
      ))
    }
  </fieldset>

  {/* Masonry wall — CSS columns. Each item carries data-category for the filter. */}
  <div class="mt-8 gap-4 [column-fill:_balance] sm:columns-2 lg:columns-3">
    {
      albums.map((a) => (
        <div class="gallery-item mb-4 break-inside-avoid" data-category={a.data.category}>
          <GalleryAlbumCard album={a} />
        </div>
      ))
    }
  </div>

  <p class="gw-empty mt-6 text-subtle" hidden>No galleries in this category yet.</p>
</div>

<script>
  // Category filter: show/hide album cards. Cards remain in the static HTML for crawlers;
  // JS only toggles visibility (same approach as the What's On filter).
  function applyGalleryFilter() {
    const sel = document.querySelector('input[name="gw-cat"]:checked') as HTMLInputElement | null;
    if (!sel) return;
    const cat = sel.value;
    let visible = 0;
    document.querySelectorAll<HTMLElement>('.gallery-item').forEach((item) => {
      const show = cat === 'all' || item.getAttribute('data-category') === cat;
      item.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    const empty = document.querySelector('.gw-empty') as HTMLElement | null;
    if (empty) empty.hidden = visible > 0;
  }

  document
    .querySelectorAll('input[name="gw-cat"]')
    .forEach((el) => el.addEventListener('change', applyGalleryFilter));
  applyGalleryFilter();
</script>
