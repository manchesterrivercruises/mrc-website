---
import SectionHeading from './SectionHeading.astro';
import GalleryAlbumCard from './GalleryAlbumCard.astro';
import type { Album } from '../lib/gallery';

// A row of related album covers (explicit relatedAlbums, or same-category fallback —
// resolved by the caller via resolveRelated()).
interface Props {
  albums: Album[];
}
const { albums } = Astro.props;
---

{
  albums.length > 0 && (
    <section aria-labelledby="related-albums" class="bg-panel">
      <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 md:py-16 lg:px-8">
        <SectionHeading id="related-albums">More galleries</SectionHeading>
        <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {albums.map((a) => (
            <GalleryAlbumCard album={a} />
          ))}
        </div>
      </div>
    </section>
  )
}
