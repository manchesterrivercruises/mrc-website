---
// Reusable amber star rating (full / half / empty), sized via `size`.
// Used for the homepage hero trust line and social-proof block.
interface Props {
  rating: number;
  size?: string; // Tailwind h-/w- size, e.g. 'h-4 w-4'
  class?: string;
}
const { rating, size = 'h-5 w-5', class: className = '' } = Astro.props;

// heroicons solid star path
const STAR =
  'M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.563.563 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z';
const fullCount = Math.floor(rating);
const hasHalf = rating - fullCount >= 0.5;
const emptyCount = 5 - fullCount - (hasHalf ? 1 : 0);
---

<span class={`inline-flex items-center text-amber-400 ${className}`} role="img" aria-label={`${rating} out of 5 stars`}>
  {Array.from({ length: fullCount }).map(() => (
    <svg class={size} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={STAR} /></svg>
  ))}
  {
    hasHalf && (
      <svg class={size} viewBox="0 0 24 24" aria-hidden="true">
        <defs>
          <linearGradient id="starRatingHalf">
            <stop offset="50%" stop-color="currentColor" />
            <stop offset="50%" stop-color="rgb(255 255 255 / 0.25)" />
          </linearGradient>
        </defs>
        <path fill="url(#starRatingHalf)" d={STAR} />
      </svg>
    )
  }
  {Array.from({ length: emptyCount }).map(() => (
    <svg class={size} viewBox="0 0 24 24" fill="rgb(255 255 255 / 0.25)" aria-hidden="true"><path d={STAR} /></svg>
  ))}
</span>
