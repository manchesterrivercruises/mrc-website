---
// ─────────────────────────────────────────────────────────────────────────────
// Shared Ventrata checkout widget — the SINGLE owner of all Ventrata client wiring.
// Three modes. Per AGENTS rule 9 the checkout loader ships SITE-WIDE: it is rendered
// once in <Header> so every page's persistent Book Now can open checkout. (Rule 9
// deliberately supersedes the earlier "booking-pages-only" guidance — this is the ~726KB
// third-party checkout bundle that Lighthouse reports as unused JS on non-booking pages;
// it is an accepted, intentional cost. See docs/lighthouse-triage.md.) Modes:
//
//   mode="loader"   Page-level setup: the checkout <script>, the modal open/close
//                   observer, and the loading-skeleton hide. Rendered ONCE site-wide by
//                   <Header> (not per page). Load it EXACTLY ONCE per page — never add a
//                   second per-page loader.
//
//   mode="embedded" Desktop embedded widget for a product. Fills a BookingPanel's
//                   "widget" slot: <VentrataWidget mode="embedded" productID={id} slot="widget" />
//
//   mode="popup"    A pop-up trigger button (mobile sticky CTA, inline CTAs):
//                       <VentrataWidget mode="popup" productID={id} label="Book Now" class="w-full" />
//
// The checkout API key below is the DOM-SAFE checkout widget key (confirmed by
// Ventrata) — NOT the OCTO connection key, which must never reach the client
// (AGENTS rules 1–2). Keep env="test" until launch, then switch to "live".
// ─────────────────────────────────────────────────────────────────────────────
import CTAButton from './CTAButton.astro';
import { VENTRATA_ENV, VENTRATA_CHECKOUT_KEY, VENTRATA_CHECKOUT_SRC } from '../data/ventrata';

interface Props {
  mode: 'loader' | 'embedded' | 'popup';
  productID?: string;
  env?: 'test' | 'live';
  /** popup: button text */
  label?: string;
  /** popup: extra classes forwarded to the trigger button */
  class?: string;
  /** embedded/popup: open the checkout on the date/calendar step (date-led browsing).
      See the calendarFirst caveat below — the exact data-config key is TBC with Ventrata. */
  calendarFirst?: boolean;
  /** embedded: min-height utility (widget must be able to grow — never a fixed height) */
  minHeightClass?: string;
}

const {
  mode,
  productID,
  // Defaults to the central VENTRATA_ENV — launch flips that ONE value (src/data/ventrata.ts).
  env = VENTRATA_ENV,
  label = 'Book Now',
  class: className = '',
  calendarFirst = false,
  minHeightClass = 'min-h-[40rem]',
} = Astro.props;

if ((mode === 'embedded' || mode === 'popup') && !productID) {
  throw new Error(`VentrataWidget mode="${mode}" requires a productID`);
}

const checkoutConfig = JSON.stringify({ apiKey: VENTRATA_CHECKOUT_KEY, env });
// `calendarFirst: true` opens the widget on the date step (date-led browsing) per
// docs/ventrata-integration.md → "Calendar First mode" — supported on both the embedded
// and pop-up variants. ⚠ The exact key name (calendarFirst vs a versioned alias) and
// which product(s) to surface / their ordering must be confirmed with the Ventrata
// account manager before launch.
const calendarFirstConfig = calendarFirst ? { calendarFirst: true } : {};
const embeddedConfig = JSON.stringify({ productID, embedded: true, ...calendarFirstConfig });
const popupConfig = JSON.stringify({ productID, ...calendarFirstConfig });

// Loader CSS + observer JS injected via set:html. IMPORTANT: Astro does NOT evaluate
// `{...}` inside <script>/<style> tag bodies — `<script>{`…`}</script>` emits the
// backticks + code LITERALLY, so the IIFE never runs. set:html sets the evaluated string
// as element content (same pattern as the JSON-LD blocks and the ReviewStrip fix).
const SKELETON_CSS = `
  /* Embedded sizing chain. Ventrata's embedded iframe GROWS to its content via height-sync
     (it does not scroll internally), so the container must wrap it exactly — never clamp it.
     - While loading (no iframe): the min-h-[40rem] floor on the aside gives the skeleton a
       height (no pre-render collapse).
     - Once the iframe mounts: hide the skeleton and RELEASE the aside floor (min-height: 0)
       so the aside is exactly the iframe's height — no dead space under short products (T2).
     - The iframe itself: full width, no border, and a MIN-HEIGHT floor (a floor, NOT a cap:
       it never clamps a taller synced height) so the first step (Select Date) stays visible
       even if the height-sync underperforms — the previous 150px default clipped it.
     CRUCIAL: never set a CSS height on the iframe — that overrides Ventrata's own height and
     collapses it to the 150px default. */
  aside[ventrata-embedded-widget]:has(iframe) .widget-loading { display: none; }
  aside[ventrata-embedded-widget]:has(iframe) { min-height: 0; }
  aside[ventrata-embedded-widget] iframe { display: block; width: 100%; border: 0; min-height: 40rem; }
`;

const OBSERVER_SCRIPT = `
(function () {
  function init() {
    var root = document.documentElement;
    var KEY = 'ventrata-open';
    var body = document.body;
    if (!body) return;

    // Body children present at load — anything added later is the third-party pop-up. Our
    // own triggers/embeds live deep in the page, never as new body children.
    var initial = new Set(Array.prototype.slice.call(body.children));

    function looksVentrata(el) {
      var hit = function (n) {
        if (!n || n.nodeType !== 1) return false;
        if (/ventrata|checkout/i.test(n.id || '')) return true;
        var c = typeof n.className === 'string' ? n.className : '';
        if (/ventrata|checkout/i.test(c)) return true;
        var at = n.attributes;
        if (at) for (var i = 0; i < at.length; i++) if (/ventrata|checkout/i.test(at[i].name)) return true;
        return false;
      };
      if (hit(el)) return true;
      var all = el.querySelectorAll ? el.querySelectorAll('*') : [];
      for (var i = 0; i < all.length; i++) if (hit(all[i])) return true;
      return false;
    }

    function shown(el) {
      var cs = getComputedStyle(el);
      if (cs.display === 'none' || cs.visibility === 'hidden') return false;
      return el.getBoundingClientRect().width > 0;
    }

    var armedTrigger = false;  // opened via a [ventrata-checkout] click → lock immediately
    var armedEmbedded = false; // interacting with an embedded aside → sensitise, lock on takeover
    var saw = false;           // an overlay appeared this session
    var currentOverlay = null; // the identified overlay node (watchdog + scroll-containment target)
    var contained = null;      // element we've set overscroll-behavior:contain on
    var failsafe = 0;
    var watchdog = 0;

    function armedAny() { return armedTrigger || armedEmbedded; }

    // ── Takeover classifier ─────────────────────────────────────────────────────────────
    // A genuine checkout takeover/pop-up is a body-level overlay that is COMPUTED
    // position:fixed (or a dialog-style body-level overlay). Rect coverage alone NEVER
    // qualifies: the inline embedded widget grows to its content height (height-sync) and can
    // legitimately cover most of the viewport in both dimensions without being a takeover —
    // classifying it as one applied the body scroll-lock to an inline widget (page scroll
    // dead, but an in-widget Leaflet map still panning: the tell-tale body-lock signature).

    // (2) The inline embed can NEVER be a takeover: anything that IS, or lives inside,
    //     [ventrata-embedded-widget] (its iframe included) is excluded outright.
    function isInlineEmbed(el) {
      return !!(el && el.nodeType === 1 && el.closest && el.closest('[ventrata-embedded-widget]'));
    }

    // First position:fixed ancestor (self included), stopping at <body>.
    function fixedAncestor(el) {
      var n = el;
      while (n && n.nodeType === 1 && n !== body) {
        if (getComputedStyle(n).position === 'fixed') return n;
        n = n.parentElement;
      }
      return null;
    }

    function isVentrataIframe(el) {
      return el.tagName === 'IFRAME' && /ventrata/i.test(el.getAttribute('src') || el.src || '');
    }

    // (1) THE core test — is el a genuine takeover overlay? It MUST be computed
    //     position:fixed, or a body-level dialog (native <dialog> / role=dialog / aria-modal,
    //     which some builds centre with margins rather than fixed). Coverage is never a
    //     substitute for this, and the inline embed never qualifies.
    function isTakeover(el) {
      if (!el || el.nodeType !== 1 || !shown(el) || isInlineEmbed(el)) return false;
      if (getComputedStyle(el).position === 'fixed') return true;
      var dialogish = el.tagName === 'DIALOG' ||
        el.getAttribute('role') === 'dialog' ||
        el.getAttribute('aria-modal') === 'true';
      return dialogish && el.parentElement === body;
    }

    // DETECTION arm (1) — INSERTION: a genuine overlay injected as a post-load body child.
    // Prefer ventrata identity; during an armed session also accept an unbranded overlay
    // (some builds inject a plain fixed backdrop) — but only if it is a genuine takeover.
    function insertedOverlay() {
      var kids = body.children, fallback = null;
      for (var i = 0; i < kids.length; i++) {
        var el = kids[i];
        if (initial.has(el) || isInlineEmbed(el) || !isTakeover(el)) continue;
        if (looksVentrata(el)) return el;
        if (armedAny() && !fallback) fallback = el;
      }
      return fallback;
    }

    // DETECTION arm (2) — REVEAL: a ventrata element/iframe promoted into a genuine fixed
    // overlay in place (no body-child insertion). A real embedded-widget fullscreen takeover
    // reparents/wraps the iframe in a position:fixed container OUTSIDE the inline embed — that
    // fixed container is what qualifies, never the inline aside merely growing tall.
    function revealedOverlay() {
      var ifr = document.getElementsByTagName ? document.getElementsByTagName('iframe') : [];
      for (var i = 0; i < ifr.length; i++) {
        var f = ifr[i];
        if (!isVentrataIframe(f) || !shown(f) || isInlineEmbed(f)) continue;
        var fa = fixedAncestor(f);
        if (fa && !isInlineEmbed(fa)) return fa; // the genuine fixed takeover container
      }
      var kids = body.children;
      for (var k = 0; k < kids.length; k++) {
        var el = kids[k];
        if (isInlineEmbed(el)) continue;
        if (looksVentrata(el) && isTakeover(el)) return el;
      }
      return null;
    }

    // The overlay = an inserted pop-up OR a revealed (in-place) fixed takeover. Both require a
    // genuine fixed/dialog overlay; neither can ever be the inline embed.
    function findOverlay() { return insertedOverlay() || revealedOverlay(); }

    // (3) Contain scroll chaining on the addressable overlay container so widget scrolling
    //     never drags the page behind. (The embedded aside also carries this in CSS.)
    function applyContain(el) {
      if (contained && contained !== el) { try { contained.style.overscrollBehavior = ''; } catch (e) {} }
      contained = el || null;
      if (el) { try { el.style.overscrollBehavior = 'contain'; } catch (e) {} }
    }

    function stopWatchdog() { if (watchdog) { clearInterval(watchdog); watchdog = 0; } }

    // BELT-AND-BRACES (3): while locked, poll ~1s and RE-VERIFY the lock is still justified.
    // The lock is only legitimate if a genuine fixed/dialog overlay is present — re-checked
    // LIVE via isTakeover(), not trusted from when it was first classified — or a trigger click
    // is still within its open grace window. If the classified element is no longer genuinely
    // fixed (collapsed back inline, removed, or hidden) the lock RELEASES. So even a FUTURE
    // misclassification (e.g. an inline widget briefly mistaken for a takeover) self-heals
    // within a second.
    function startWatchdog() {
      if (watchdog) return;
      watchdog = window.setInterval(function () {
        if (!root.classList.contains(KEY)) return; // not locked — nothing to police
        // Drop the current classification the moment it stops being a genuine fixed overlay.
        if (currentOverlay && (!document.contains(currentOverlay) || !isTakeover(currentOverlay))) {
          currentOverlay = null;
        }
        var still = currentOverlay || findOverlay();
        if (still) { currentOverlay = still; saw = true; applyContain(still); return; }
        if (armedTrigger && !saw) return; // trigger pop-up still opening; the failsafe times it out
        forceClose();
      }, 1000);
    }

    // Unconditionally release the lock and reset state.
    function forceClose() {
      armedTrigger = false; armedEmbedded = false; saw = false; currentOverlay = null;
      clearTimeout(failsafe);
      stopWatchdog();
      applyContain(null);
      root.classList.remove(KEY);
    }

    function evaluate() {
      var overlay = findOverlay();
      if (overlay) { saw = true; currentOverlay = overlay; }
      var present = !!overlay;
      if (saw && !present) { armedTrigger = false; armedEmbedded = false; saw = false; currentOverlay = null; } // closed
      // Embedded arming does NOT lock on its own (inline desktop use must keep its chrome) —
      // only a trigger click or an actual overlay locks.
      var open = armedTrigger || present;
      root.classList.toggle(KEY, open);
      applyContain(open ? currentOverlay : null);
      if (open) startWatchdog(); else stopWatchdog();
    }

    var raf = 0;
    function schedule() {
      if (!raf) raf = requestAnimationFrame(function () { raf = 0; evaluate(); });
    }

    // ARM (a) — TRIGGER: a click on any [ventrata-checkout] element opens a pop-up immediately,
    // before the widget injects its DOM, so chrome hides with no flicker.
    document.addEventListener('click', function (e) {
      var t = e.target;
      if (t && t.closest && t.closest('[ventrata-checkout]')) {
        armedTrigger = true;
        saw = false;
        currentOverlay = null;
        root.classList.add(KEY);
        startWatchdog();
        clearTimeout(failsafe);
        // If the pop-up never opens, release so the chrome isn't hidden forever.
        failsafe = window.setTimeout(function () { if (armedTrigger && !saw) forceClose(); }, 5000);
      }
    }, true);

    // ARM (b) — EMBEDDED: interacting with an embedded aside can expand it to a fullscreen
    // takeover with NO trigger click, and may restyle an existing element rather than inject a
    // body child (evading both old arms). Sensitise detection here (do NOT lock yet — an inline
    // desktop widget must keep its chrome), then nudge evaluate so the takeover is caught the
    // instant it appears; the MutationObserver + reveal detection do the actual locking.
    document.addEventListener('pointerdown', function (e) {
      var t = e.target;
      if (t && t.closest && t.closest('[ventrata-embedded-widget]')) {
        armedEmbedded = true;
        clearTimeout(failsafe);
        failsafe = window.setTimeout(function () {
          if (!saw) { armedEmbedded = false; if (!root.classList.contains(KEY)) stopWatchdog(); }
        }, 5000);
        setTimeout(evaluate, 60);
        setTimeout(evaluate, 300);
        setTimeout(evaluate, 900);
      }
    }, true);

    // Skeleton fallback: remove the "Loading…" node as soon as ANY real content appears
    // ANYWHERE inside an embedded aside (covers a widget rendered without an iframe).
    function hideLoadedSkeletons() {
      var asides = document.querySelectorAll('aside[ventrata-embedded-widget]');
      for (var i = 0; i < asides.length; i++) {
        var aside = asides[i];
        var skeleton = aside.querySelector('.widget-loading');
        if (!skeleton) continue;
        var nodes = aside.querySelectorAll('*');
        for (var j = 0; j < nodes.length; j++) {
          var el = nodes[j];
          if (el === skeleton || skeleton.contains(el)) continue; // skip the skeleton itself
          skeleton.remove();
          aside.style.minHeight = '0'; // release the floor (fallback for a no-iframe render)
          break;
        }
      }
    }

    // OBSERVE: body childList + attribute (style/class/hidden/size) mutations drive open/close
    // detection — crucially, the REVEAL arm needs attribute mutations, since the takeover locks
    // by restyling an element (inline style → position:fixed / full-viewport) with no insertion.
    // Same observer also drives the skeleton fallback.
    new MutationObserver(function () {
      schedule();
      hideLoadedSkeletons();
    }).observe(body, { childList: true, subtree: true, attributes: true, attributeFilter: ['style', 'class', 'hidden', 'width', 'height'] });

    // (3) Extra removal hints — Ventrata's teardown isn't always a body childList mutation.
    //     Escape usually closes the pop-up; re-check just after it tears down.
    document.addEventListener('keydown', function (e) {
      if ((e.key === 'Escape' || e.keyCode === 27) && root.classList.contains(KEY)) {
        setTimeout(evaluate, 250);
        setTimeout(evaluate, 800);
      }
    });
    // In-page navigation (e.g. a checkout success redirect) can drop the pop-up silently.
    window.addEventListener('popstate', function () { setTimeout(evaluate, 0); });
    // Never strand a locked page across back/forward (bfcache) navigation or tab teardown.
    window.addEventListener('pagehide', forceClose);
    document.addEventListener('visibilitychange', function () {
      if (document.visibilityState === 'hidden') forceClose();
      else evaluate(); // returning to a still-open pop-up re-locks
    });

    // MARKETING-LINK AUTO-OPEN (docs → "Marketing links that auto-open checkout"): the date
    // finder links departures to a product page with ?openWidget=true&date=YYYY-MM-DD[&time=HH:MM];
    // "Join waitlist" on a sold-out departure uses the same link. Open the checkout for THIS page's
    // product, preselecting that date.
    //
    // KEY NAMES ARE CONFIRMED: dateToPreselect (YYYY-MM-DD) + timeslotToPreselect (HH:MM) are the
    // supported inputs per Ventrata's "Supported Configuration Inputs" doc — so a wrong key is NOT
    // the cause of a missed preselect. Two real suspects remain, which on-device QA must separate:
    //   1. SOLD-OUT date — Ventrata's calendar is availability-aware (see "Preselect the first
    //      AVAILABLE date"); it will not preselect an unbuyable date, so a WAITLIST deep link
    //      (sold-out by definition) can't preselect. Test an AVAILABLE date to confirm.
    //   2. OUR SIDE — the trigger below is created dynamically; if Ventrata only reads preselect
    //      from load-time triggers/script config, the key is right but ignored.
    // calendarFirst is intentionally NOT sent with a date — it opens the calendar BROWSE step and
    // competes with a specific preselect; the documented date-preselect examples omit it.
    function autoOpenFromUrl() {
      var q; try { q = new URLSearchParams(window.location.search); } catch (e) { return; }
      if (!q.get('openWidget')) return;
      var host = document.querySelector('[ventrata-embedded-widget][data-config], [ventrata-checkout][data-config]');
      var productID = null;
      if (host) { try { productID = JSON.parse(host.getAttribute('data-config')).productID; } catch (e) {} }
      if (!productID) return;

      var cfg = { productID: productID };
      var date = q.get('date');
      if (date && /^[0-9]{4}-[0-9]{2}-[0-9]{2}$/.test(date)) {
        cfg.dateToPreselect = date; // confirmed key
        var time = q.get('time');
        if (time && /^[0-9]{2}:[0-9]{2}$/.test(time)) cfg.timeslotToPreselect = time; // confirmed key
      } else {
        cfg.calendarFirst = true; // no specific date → open on the calendar step for browsing
      }

      // TEMPORARY DIAGNOSTIC — remove after on-device QA. Logs the EXACT config handed to the
      // trigger so one device check distinguishes right-but-ignored (Ventrata side, e.g. a
      // sold-out date it refuses to preselect) from wrong/missing (our side).
      try { console.debug('[MRC][ventrata] auto-open config →', JSON.stringify(cfg)); } catch (e) {}

      var btn = document.createElement('button');
      btn.type = 'button';
      btn.setAttribute('ventrata-checkout', '');
      btn.setAttribute('data-config', JSON.stringify(cfg));
      btn.style.cssText = 'position:fixed;left:-9999px;width:1px;height:1px;';
      body.appendChild(btn);
      // Let the deferred checkout module initialise, then trigger it. The click also propagates
      // to our own arm(a) handler, so chrome hides even before the pop-up DOM appears.
      window.setTimeout(function () { btn.click(); }, 400);
    }

    // ── Embedded-widget focus-theft guard ──────────────────────────────────────────────────
    // The Ventrata embed can autofocus a field inside its iframe as it loads, stealing keyboard
    // focus: the browser scrolls the iframe into view (the page "jumps just below the widget")
    // and arrow keys then go into the iframe until the user clicks back into the document. This
    // counteracts ONLY that UNPROMPTED steal — during a short window after the iframe mounts and
    // only while the user hasn't taken control. User-initiated focus (clicking in, tabbing in) is
    // never touched.
    function setupFocusGuard() {
      var aside = document.querySelector('[ventrata-embedded-widget]');
      if (!aside) return; // no embedded widget on this page
      var focusTarget = document.getElementById('main') || body;

      var guardActive = false;
      var engaged = false; // user genuinely used the widget → never interfere again
      var lastTabAt = 0;   // last Tab keydown = a genuine focus move (possibly INTO the widget)
      var lastDocScroll = { x: window.scrollX || 0, y: window.scrollY || 0 };
      var rafId = 0, timer = 0, mountObs = null;

      function inWidget(node) { return !!(node && node.closest && node.closest('[ventrata-embedded-widget]')); }
      function isWidgetIframe(el) { return !!(el && el.tagName === 'IFRAME' && inWidget(el)); }

      function stopGuard() {
        guardActive = false;
        if (timer) { clearTimeout(timer); timer = 0; }
        if (rafId) { cancelAnimationFrame(rafId); rafId = 0; }
        document.removeEventListener('focusin', onFocusIn, true);
        window.removeEventListener('blur', onWinBlur, true);
      }

      // Remember the document scroll position WHILE focus is on the page (never while the iframe
      // holds it), so a theft jump can be undone to the pre-jump position.
      function sample() {
        if (!guardActive) return;
        if (!isWidgetIframe(document.activeElement)) { lastDocScroll.x = window.scrollX || 0; lastDocScroll.y = window.scrollY || 0; }
        rafId = requestAnimationFrame(sample);
      }

      function neutralise() {
        if (!guardActive || engaged) return;
        var thief = document.activeElement;
        if (!isWidgetIframe(thief)) return;
        if (Date.now() - lastTabAt < 700) return; // user tabbed into the widget — leave it
        try { console.debug('[MRC][ventrata] focus theft neutralised — activeElement was', thief && thief.tagName, thief); } catch (e) {}
        try { if (thief.blur) thief.blur(); } catch (e) {}
        try { focusTarget.setAttribute('tabindex', '-1'); focusTarget.focus({ preventScroll: true }); } catch (e) {}
        try { window.scrollTo(lastDocScroll.x, lastDocScroll.y); } catch (e) {} // undo the jump
      }
      function onFocusIn(e) { if (isWidgetIframe(e.target)) neutralise(); }
      function onWinBlur() { neutralise(); }

      // A pointerdown anywhere = the user has taken control → close the window. In the widget =
      // the user wants it → never interfere again.
      document.addEventListener('pointerdown', function (e) {
        if (inWidget(e.target)) engaged = true;
        stopGuard();
      }, true);
      // Tab is a genuine focus move (maybe INTO the widget) — record it so the resulting iframe
      // focus isn't mistaken for a steal. Arrows/other keys do NOT move focus, so an iframe focus
      // after them is unprompted. Any keydown INSIDE the widget = engaged.
      document.addEventListener('keydown', function (e) {
        if (inWidget(e.target)) { engaged = true; stopGuard(); return; }
        if (e.key === 'Tab' || e.keyCode === 9) lastTabAt = Date.now();
      }, true);

      function startGuard() {
        if (guardActive || engaged) return;
        guardActive = true;
        document.addEventListener('focusin', onFocusIn, true);
        window.addEventListener('blur', onWinBlur, true);
        rafId = requestAnimationFrame(sample);
        timer = window.setTimeout(stopGuard, 3000); // ~3s window
        neutralise(); // in case the iframe grabbed focus before we started listening
      }

      // Start the window when the embed's iframe first mounts (nothing can steal focus before
      // then). If it's already present, start now.
      if (aside.querySelector('iframe')) startGuard();
      else {
        mountObs = new MutationObserver(function () {
          if (aside.querySelector('iframe')) { mountObs.disconnect(); mountObs = null; startGuard(); }
        });
        mountObs.observe(aside, { childList: true, subtree: true });
      }
    }

    hideLoadedSkeletons();
    evaluate();
    autoOpenFromUrl();
    setupFocusGuard();
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();
`;
---

{
  mode === 'loader' && (
    <Fragment>
      {/* Warm the connections the checkout needs — the widget script host and the Ventrata API
          the widget calls (connect-src in netlify.toml) — so the TLS handshake overlaps parsing
          instead of starting when the deferred module runs. Booking pages only (loader mode). */}
      <link rel="preconnect" href="https://cdn.checkout.ventrata.com" crossorigin />
      <link rel="preconnect" href="https://api.ventrata.com" crossorigin />

      {/* Checkout script — loaded only on this page, never globally (AGENTS rule 9).
          type="module" so it defers; is:inline so Astro keeps the external src +
          data-config intact instead of trying to bundle it. */}
      <script is:inline type="module" src={VENTRATA_CHECKOUT_SRC} data-config={checkoutConfig} />

      {/* Hide the loading skeleton once the embedded widget renders. Ventrata mounts its
          checkout in an IFRAME, but not always as a direct child of the aside (it can nest
          it in a wrapper) — so match the iframe ANYWHERE in the subtree (:has(iframe)) and
          hide the skeleton as a DESCENDANT, never assuming a direct-child relationship. The
          old `:has(> :not(.widget-loading)) > .widget-loading` only fired when the injected
          node landed as a direct sibling of the skeleton, which is why the skeleton stuck on
          some products. The script below is the belt-and-suspenders fallback for the (rare)
          case where the widget renders without an iframe. :has() is within our baseline. */}
      {/* set:html — NOT `<style>{`…`}</style>` / `<script>{`…`}</script>` (Astro emits
          those bodies LITERALLY, so nothing runs). Injects the evaluated strings above. */}
      <style is:global set:html={SKELETON_CSS} />

      {/* Ventrata checkout pop-up observer — ships ONLY on booking pages. Toggles
          `ventrata-open` on <html> so the pop-up owns the screen (styling in global.css).
          Identity-based detection; DOMContentLoaded-guarded because it lives in <head>. */}
      <script is:inline set:html={OBSERVER_SCRIPT} />
    </Fragment>
  )
}

{
  mode === 'embedded' && (
    <aside
      class={`${minHeightClass} h-auto w-full`}
      ventrata-embedded-widget
      data-config={embeddedConfig}
    >
      <div class="widget-loading">Loading availability&hellip;</div>
    </aside>
  )
}

{
  mode === 'popup' && (
    <CTAButton class={className} ventrata-checkout="" data-config={popupConfig}>
      {label}
    </CTAButton>
  )
}
