---
import SectionHeading from './SectionHeading.astro';

// Star rating summary + review cards.
//
// `live` turns on progressive enhancement: a small client script fetches
// /.netlify/functions/reviews, swaps in the live aggregate rating/count and rotates the
// returned quote cards one at a time. The server-rendered aggregate below is the SEO
// baseline and the silent fallback — on ANY fetch failure nothing changes. NO schema.org
// markup is emitted for fetched reviews (Google prohibits marking up Google reviews).
interface Props {
  rating: number;
  reviewCount: number;
  reviewsHref?: string;
  id?: string;
  title?: string;
  reviews?: { quote: string; author: string }[];
  /** Fetch + rotate live Google reviews as an enhancement (see /.netlify/functions/reviews). */
  live?: boolean;
}
const {
  rating,
  reviewCount,
  reviewsHref,
  id = 'reviews',
  title = 'Reviews',
  // No placeholder quotes: static quote cards render ONLY when real reviews are passed in
  // (non-live callers). Live callers get JS-rendered rotating cards instead.
  reviews = [],
  live = false,
} = Astro.props;

// Only link the aggregate count out when we have a real destination URL — otherwise
// render it as plain text rather than a dead "#" link.
const hasReviewsLink = typeof reviewsHref === 'string' && reviewsHref !== '' && reviewsHref !== '#';

// heroicons solid star path
const STAR =
  'M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.563.563 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z';
const fullCount = Math.floor(rating);
const hasHalf = rating - fullCount >= 0.5;
const emptyCount = 5 - fullCount - (hasHalf ? 1 : 0);

// Client script + rotator CSS injected via set:html. IMPORTANT: Astro does NOT evaluate
// `{...}` expressions inside <script>/<style> tag bodies — writing `<script>{`…`}</script>`
// emits the backticks + code LITERALLY, so the IIFE never runs (it becomes a template
// string). set:html evaluates the expression and sets it as the element's content, the
// same proven pattern the JSON-LD blocks use.
const ROTATOR_CSS = `
  .rs-rotator:not([hidden]) { display: grid; }
  .rs-slide {
    grid-area: 1 / 1;
    opacity: 0;
    visibility: hidden;
    /* Crossfade: fade opacity, then flip visibility AFTER the fade so the outgoing slide
       stays visible during the transition and inactive slides leave the tab order. */
    transition: opacity 0.6s ease, visibility 0s 0.6s;
  }
  .rs-slide.rs-active {
    opacity: 1;
    visibility: visible;
    transition: opacity 0.6s ease, visibility 0s 0s;
  }
  @media (prefers-reduced-motion: reduce) { .rs-slide { transition: none; } }
`;

const REVIEWS_SCRIPT = `
(function () {
  var root = document.querySelector('[data-review-rotator]');
  if (!root) return;
  var scope = root.closest('section') || document;
  var ratingEl = scope.querySelector('[data-review-rating]');
  var countEl = scope.querySelector('[data-review-count]');

  fetch('/.netlify/functions/reviews', { headers: { Accept: 'application/json' } })
    .then(function (res) { if (!res.ok) throw new Error('HTTP ' + res.status); return res.json(); })
    .then(function (data) {
      if (!data || typeof data !== 'object') { console.debug('ReviewStrip: unexpected payload', data); return; }

      // Drive the aggregate from the fetched values (live count, not the hardcoded fallback).
      // Accept the trimmed shape ({rating,count}) or raw Google field names.
      var rating = typeof data.rating === 'number' ? data.rating
        : (typeof data.averageRating === 'number' ? data.averageRating : null);
      var count = typeof data.count === 'number' ? data.count
        : (typeof data.userRatingCount === 'number' ? data.userRatingCount
          : (typeof data.reviewCount === 'number' ? data.reviewCount : null));
      if (ratingEl && rating !== null) ratingEl.textContent = String(Math.round(rating * 10) / 10);
      if (countEl && count !== null) countEl.textContent = count.toLocaleString() + ' Google reviews';

      var reviews = Array.isArray(data.reviews) ? data.reviews : [];
      if (!reviews.length) { console.debug('ReviewStrip: payload had no reviews array', data); return; }

      var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      var slides = [];
      reviews.forEach(function (r) {
        if (!r) return;
        // Normalise each review — trimmed (text/author/time) or raw Google fields.
        var text = typeof r.text === 'string' ? r.text : (r.text && r.text.text) || '';
        if (!text) return;
        var author = r.author || (r.authorAttribution && r.authorAttribution.displayName) || 'Guest';
        var time = r.time || r.relativePublishTimeDescription || '';
        var ratingN = typeof r.rating === 'number' ? r.rating : 5;

        var fig = document.createElement('figure');
        fig.className = 'rs-slide rounded-card bg-panel p-6 shadow-sm ring-1 ring-black/5';

        var n = Math.max(1, Math.min(5, Math.round(ratingN)));
        var stars = document.createElement('div');
        stars.className = 'text-amber-400';
        stars.setAttribute('aria-label', 'Rated ' + n + ' out of 5');
        stars.textContent = '★★★★★'.slice(0, n);

        var q = document.createElement('blockquote');
        q.className = 'mt-2 leading-relaxed text-body';
        q.textContent = text;

        var cap = document.createElement('figcaption');
        cap.className = 'mt-4 text-sm text-subtle';
        cap.textContent = author + (time ? ' · ' + time : '');

        fig.appendChild(stars);
        fig.appendChild(q);
        fig.appendChild(cap);
        root.appendChild(fig);
        slides.push(fig);
      });
      if (!slides.length) return;

      root.hidden = false;
      var idx = 0;
      function show(i) {
        for (var j = 0; j < slides.length; j++) {
          var active = j === i;
          slides[j].classList.toggle('rs-active', active);
          if (active) slides[j].removeAttribute('aria-hidden');
          else slides[j].setAttribute('aria-hidden', 'true');
        }
      }
      show(0);

      if (reduce || slides.length < 2) return; // reduced motion or a single review: static

      var paused = false;
      window.setInterval(function () { if (paused) return; idx = (idx + 1) % slides.length; show(idx); }, 8000);
      root.addEventListener('mouseenter', function () { paused = true; });
      root.addEventListener('mouseleave', function () { paused = false; });
      root.addEventListener('focusin', function () { paused = true; });
      root.addEventListener('focusout', function () { paused = false; });
    })
    .catch(function (err) {
      // Not user-visible — the static server-rendered aggregate stays. Log the reason
      // (fetch/network/CORS/shape) so a silent failure is diagnosable.
      if (window.console && console.debug) console.debug('ReviewStrip: live reviews unavailable —', err);
    });
})();
`;
---

<section aria-labelledby={id}>
  <SectionHeading id={id}>{title}</SectionHeading>

  <div class="mt-6 flex flex-wrap items-center gap-4 rounded-card bg-panel p-5 ring-1 ring-black/5">
    <div class="text-4xl font-bold text-ink" data-review-rating>{rating}</div>
    <div>
      <div class="flex items-center text-amber-400" aria-hidden="true">
        {Array.from({ length: fullCount }).map(() => (
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d={STAR} /></svg>
        ))}
        {hasHalf && (
          <svg class="h-5 w-5" viewBox="0 0 24 24">
            <defs>
              <linearGradient id="reviewHalfStar">
                <stop offset="50%" stop-color="currentColor" />
                <stop offset="50%" stop-color="rgb(0 0 0 / 0.12)" />
              </linearGradient>
            </defs>
            <path fill="url(#reviewHalfStar)" d={STAR} />
          </svg>
        )}
        {Array.from({ length: emptyCount }).map(() => (
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="rgb(0 0 0 / 0.12)"><path d={STAR} /></svg>
        ))}
      </div>
      {
        hasReviewsLink ? (
          <a href={reviewsHref} class="mt-1 inline-block text-sm font-medium text-primary hover:underline" data-review-count>
            {reviewCount} Google reviews
          </a>
        ) : (
          <p class="mt-1 text-sm font-medium text-subtle" data-review-count>{reviewCount} Google reviews</p>
        )
      }
    </div>
  </div>

  {/* Static quote cards — non-live callers only, shown when real reviews are supplied. */}
  {
    !live && reviews.length > 0 && (
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {reviews.map((r) => (
          <figure class="rounded-card bg-panel p-6 shadow-sm ring-1 ring-black/5">
            <blockquote class="leading-relaxed text-body">{r.quote}</blockquote>
            <figcaption class="mt-4 text-sm text-subtle">{r.author}</figcaption>
          </figure>
        ))}
      </div>
    )
  }

  {/* Live reviews rotator — populated by the script below on a successful fetch. Empty +
      hidden until then, so the static aggregate above is the SEO/no-JS baseline. */}
  {
    live && (
      <>
        <div class="rs-rotator mt-6" data-review-rotator hidden />

        {/* set:html — NOT `<style>{`…`}</style>` / `<script>{`…`}</script>`: Astro emits
            `{…}` inside script/style tag bodies LITERALLY (the backticks + code become
            text), so the IIFE never executes. set:html injects the evaluated string. */}
        <style is:global set:html={ROTATOR_CSS} />
        <script is:inline set:html={REVIEWS_SCRIPT} />
      </>
    )
  }
</section>
