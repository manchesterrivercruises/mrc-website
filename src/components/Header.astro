---
import Nav from './Nav.astro';
import VentrataWidget from './VentrataWidget.astro';

interface Props {
  /** Primary product for this page — the header Book Now opens that product's checkout.
      Omit on generic pages to open Ventrata's all-products chooser instead. */
  bookProductID?: string;
}
const { bookProductID } = Astro.props;

// data-config for the header Book Now trigger: a specific product where the page has one,
// else an empty object → Ventrata's all-products chooser (dashboard controls its order).
const bookConfig = bookProductID ? JSON.stringify({ productID: bookProductID }) : '{}';
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-dark text-white">
  <div class="relative mx-auto flex h-16 max-w-7xl items-center justify-between gap-4 px-4 sm:px-6 lg:px-8">
    {/* Brand logo — reversed (white) landscape master logo. Plain <img> from public/
        (not astro:assets) per docs/image-conventions.md; explicit width/height keep the
        aspect ratio (2461×686) reserved so there's no layout shift. */}
    <a href="/" class="shrink-0" aria-label="Manchester River Cruises — home">
      <img
        src="/images/logo-white.png"
        alt="Manchester River Cruises"
        width="144"
        height="40"
        class="h-10 w-auto"
      />
    </a>

    {/* Primary navigation */}
    <Nav />

    <div class="flex items-center gap-1 sm:gap-2">
      {/* Persistent Book Now — a Ventrata checkout pop-up trigger. With a page primary
          product it opens that product; otherwise the all-products chooser. href="/whats-on"
          is the no-JS fallback (Ventrata intercepts the click when its script is active). */}
      <a
        href="/whats-on"
        ventrata-checkout
        data-config={bookConfig}
        class="btn btn-primary text-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
      >
        Book Now
      </a>

      {/* Hamburger — real button toggling the mobile menu (aria-expanded/aria-controls) */}
      <button
        id="nav-toggle-btn"
        type="button"
        aria-controls="primary-nav"
        aria-expanded="false"
        class="inline-flex items-center rounded-md p-2 text-white/80 transition-colors hover:bg-white/10 hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary md:hidden"
      >
        <span class="sr-only nav-label-open">Open main menu</span>
        <span class="sr-only nav-label-close">Close main menu</span>
        <svg class="nav-icon-open h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg class="nav-icon-close h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>
</header>

<style>
  /* Icon + sr-only label swap driven by the button's own aria-expanded state. */
  #nav-toggle-btn .nav-icon-close,
  #nav-toggle-btn .nav-label-close { display: none; }
  #nav-toggle-btn[aria-expanded='true'] .nav-icon-open,
  #nav-toggle-btn[aria-expanded='true'] .nav-label-open { display: none; }
  #nav-toggle-btn[aria-expanded='true'] .nav-icon-close { display: block; }
</style>

<script>
  // Mobile nav toggle: real button semantics (aria-expanded), Escape to close, and the
  // menu drops out of the tab order when closed (display:none on the mobile panel).
  const btn = document.getElementById('nav-toggle-btn');
  const nav = document.getElementById('primary-nav');
  if (btn && nav) {
    const open = () => {
      btn.setAttribute('aria-expanded', 'true');
      nav.classList.remove('hidden');
      nav.classList.add('flex');
    };
    const close = () => {
      btn.setAttribute('aria-expanded', 'false');
      nav.classList.remove('flex');
      nav.classList.add('hidden');
    };
    btn.addEventListener('click', () => {
      btn.getAttribute('aria-expanded') === 'true' ? close() : open();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') {
        close();
        btn.focus();
      }
    });
    // Reset to a clean closed state when crossing to desktop, so the desktop nav (md:flex)
    // shows and returning to mobile starts collapsed.
    const desktop = window.matchMedia('(min-width: 768px)');
    const syncToDesktop = (e) => { if (e.matches) close(); };
    desktop.addEventListener('change', syncToDesktop);
  }
</script>

{/* Ventrata checkout loader — SITE-WIDE via the header so every page's Book Now can open
    the checkout (AGENTS rule 9). The checkout script is type="module" (deferred); the
    observer is DOMContentLoaded-guarded, so body placement is fine. Exactly one per page. */}
<VentrataWidget mode="loader" />
