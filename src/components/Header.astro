---
import Nav from './Nav.astro';
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-dark text-white">
  <div class="relative mx-auto flex h-16 max-w-7xl items-center justify-between gap-4 px-4 sm:px-6 lg:px-8">
    {/* Brand logo — reversed (white) landscape master logo. Plain <img> from public/
        (not astro:assets) per docs/image-conventions.md; explicit width/height keep the
        aspect ratio (2461×686) reserved so there's no layout shift. */}
    <a href="/" class="shrink-0" aria-label="Manchester River Cruises — home">
      <img
        src="/images/logo-white.png"
        alt="Manchester River Cruises"
        width="144"
        height="40"
        class="h-10 w-auto"
      />
    </a>

    {/* Mobile nav toggle — pure CSS, no JavaScript. Peer of <Nav> below. */}
    <input
      id="nav-toggle"
      type="checkbox"
      class="peer hidden"
      aria-label="Toggle navigation menu"
    />

    {/* Primary navigation */}
    <Nav />

    <div class="flex items-center gap-1 sm:gap-2">
      {/* Persistent Book Now CTA (points to the primary product for now) */}
      <a
        href="/city-river-tour"
        class="btn btn-primary text-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
      >
        Book Now
      </a>

      {/* Hamburger — toggles the mobile menu via the checkbox above */}
      <label
        for="nav-toggle"
        class="inline-flex cursor-pointer items-center rounded-md p-2 text-white/80 transition-colors hover:bg-white/10 hover:text-white md:hidden"
      >
        <span class="sr-only">Open main menu</span>
        <svg
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </label>
    </div>
  </div>
</header>
