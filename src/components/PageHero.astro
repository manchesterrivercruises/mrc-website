---
// Shared dark-navy page hero (eyebrow, title, subtitle, optional CTA slot).
// The default slot renders below the subtitle — pass CTAButton(s) into it.
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
}
const { eyebrow, title, subtitle } = Astro.props;
const hasCta = Astro.slots.has('default');
---

<section class="bg-dark text-white">
  <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 md:py-24 lg:px-8">
    {eyebrow && <p class="text-sm font-semibold uppercase tracking-[0.2em] text-accent">{eyebrow}</p>}
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl md:text-6xl">{title}</h1>
    {subtitle && <p class="mt-5 max-w-2xl text-lg leading-relaxed text-white/80">{subtitle}</p>}
    {hasCta && <div class="mt-8 flex flex-wrap items-center gap-4"><slot /></div>}
  </div>
</section>
