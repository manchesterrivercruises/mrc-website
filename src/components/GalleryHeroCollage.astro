---
// Gallery hero collage — a small cluster of owned photos beside the /gallery hero text.
// Images are chosen at build time by getHeroCollageImages() (owned only: isFeatured → covers
// → other owned; never placeholders/hotlinks). Alt text is carried from each source image.
//
// Desktop (md+): a clean tile cluster of up to 4 images, subtle radius + shadow.
// Mobile: a single compact strip of up to 3 thumbs under the text, so the hero stays short.
//
// The page only renders this when >= 2 images qualify (else the plain hero shows).
import type { HeroCollageImage } from '../lib/gallery';

interface Props {
  images: HeroCollageImage[];
}
const { images } = Astro.props;

const grid = images.slice(0, 4); // desktop cluster
const strip = images.slice(0, 3); // mobile strip
const n = grid.length;

// Desktop tile aspect per image. With 3 images the first tile goes wide across both columns
// for a balanced cluster; 2 or 4 images tile evenly.
function tileClass(i: number): string {
  if (n === 3 && i === 0) return 'col-span-2 aspect-[16/9]';
  if (n === 2) return 'aspect-[3/4]';
  return 'aspect-[4/3]';
}
---

{/* Desktop cluster */}
<div class="hidden grid-cols-2 gap-3 md:grid">
  {
    grid.map((img, i) => (
      <div class:list={['overflow-hidden rounded-2xl shadow-xl ring-1 ring-white/10', tileClass(i)]}>
        <img
          src={img.src}
          alt={img.alt}
          width={img.width}
          height={img.height}
          loading="eager"
          decoding="async"
          class="h-full w-full object-cover"
        />
      </div>
    ))
  }
</div>

{/* Mobile strip — kept compact so the hero never crowds on small screens */}
<div class="flex gap-2 md:hidden">
  {
    strip.map((img) => (
      <div class="h-16 w-24 flex-none overflow-hidden rounded-lg ring-1 ring-white/10">
        <img
          src={img.src}
          alt={img.alt}
          loading="eager"
          decoding="async"
          class="h-full w-full object-cover"
        />
      </div>
    ))
  }
</div>
