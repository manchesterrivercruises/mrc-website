---
// Attraction card (image, name, description, link) — used for "Make a day of it".
interface Props {
  name: string;
  desc: string;
  href: string;
  linkText?: string;
  imageLabel?: string;
}
const { name, desc, href, linkText = 'Find out more', imageLabel = 'Image (TBC)' } = Astro.props;
const external = href.startsWith('http');
---

<article
  class="group flex flex-col overflow-hidden rounded-card bg-white shadow-sm ring-1 ring-black/5 transition hover:-translate-y-0.5 hover:shadow-md hover:ring-black/10"
>
  <div class="flex aspect-[16/9] items-center justify-center bg-panel text-xs text-subtle">
    {imageLabel}
  </div>
  <div class="flex flex-1 flex-col p-4">
    <h3 class="font-semibold text-ink">{name}</h3>
    <p class="mt-1 text-sm leading-relaxed text-subtle">{desc}</p>
    <a
      href={href}
      target={external ? '_blank' : undefined}
      rel={external ? 'noopener' : undefined}
      class="mt-3 inline-block text-sm font-medium text-primary hover:underline"
    >
      {linkText}
    </a>
  </div>
</article>
