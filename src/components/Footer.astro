---
import { site } from '../data/site';

const year = new Date().getFullYear();

// Social profiles from site.ts. Inline brand SVG glyphs (24×24) — no dependency.
// Tripadvisor renders as a text link (its owl mark is too fiddly to inline cleanly).
const socialIcons = [
  {
    label: 'Facebook',
    href: site.socials.facebook,
    icon: '<path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898v-2.89h2.54V9.797c0-2.507 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>',
  },
  {
    label: 'Instagram',
    href: site.socials.instagram,
    icon: '<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>',
  },
  {
    label: 'TikTok',
    href: site.socials.tiktok,
    icon: '<path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>',
  },
];
---

<footer class="border-t border-white/10 bg-dark text-white/60">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3">
      {/* Brand */}
      <div>
        {/* Reversed (white) landscape logo on the navy footer. Plain <img> from public/
            per docs/image-conventions.md; explicit width/height reserve the 2461×686 ratio. */}
        <img
          src="/images/logo-white.png"
          alt="Manchester River Cruises"
          width="144"
          height="40"
          class="h-10 w-auto"
        />
        <p class="mt-3 max-w-xs text-sm text-white/60">
          Sightseeing cruises and private hire on the Manchester Ship Canal from Salford Quays.
        </p>
      </div>

      {/* Contact details — NAP sourced from src/data/site.ts (single source of truth) */}
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-wider text-white">Contact</h2>
        <address class="mt-4 space-y-2 text-sm not-italic text-white/60">
          <p>{site.addressDisplay}</p>
          <p>
            <a href={`mailto:${site.email}`} class="transition-colors hover:text-white">
              {site.email}
            </a>
          </p>
          <p>
            <a href={site.phoneHref} class="transition-colors hover:text-white">{site.phone}</a>
          </p>
        </address>
      </div>

      {/* Social links + Manage My Booking */}
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-wider text-white">Follow us</h2>
        <ul class="mt-4 flex flex-wrap items-center gap-4">
          {
            socialIcons.map((s) => (
              <li>
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener"
                  aria-label={s.label}
                  class="inline-flex p-2 text-white/60 transition-colors hover:text-white"
                >
                  {/* p-2 grows the 20px icon to a ~36px tap target (WCAG 2.2 24px min). */}
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={s.icon} />
                </a>
              </li>
            ))
          }
          <li>
            <a
              href={site.socials.tripadvisor}
              target="_blank"
              rel="noopener"
              class="text-sm text-white/60 transition-colors hover:text-white"
            >
              Tripadvisor
            </a>
          </li>
        </ul>
        {/* py-1.5 on each link makes the stacked targets ≥24px tall (WCAG 2.2); gap-1 keeps
            the overall block height close to the previous gap-3 layout. */}
        <div class="mt-6 flex flex-col items-start gap-1 text-sm font-medium">
          <a href="/discover" class="py-1.5 text-accent transition-colors hover:underline">Discover</a>
          <a href="/gallery" class="py-1.5 text-accent transition-colors hover:underline">Gallery</a>
          <a href="/groups" class="py-1.5 text-accent transition-colors hover:underline">Groups &amp; schools</a>
          <a href="/manage-booking" class="py-1.5 text-accent transition-colors hover:underline">Manage My Booking</a>
        </div>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-2 border-t border-white/10 pt-6 text-xs text-white/60 sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {year} Manchester River Cruises. All rights reserved.</p>
      <p>
        <a href="/privacy-policy" class="transition-colors hover:text-white">Privacy Policy</a>
      </p>
    </div>
  </div>
</footer>
