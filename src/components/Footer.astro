---
import { site } from '../data/site';

const year = new Date().getFullYear();

// Social links placeholder — real profile URLs TBC from Simon.
const social = [
  { label: 'Facebook', href: '#' },
  { label: 'Instagram', href: '#' },
  { label: 'Tripadvisor', href: '#' },
];
---

<footer class="border-t border-white/10 bg-dark text-white/60">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3">
      {/* Brand */}
      <div>
        <p class="text-lg font-semibold text-white">{site.name}</p>
        <p class="mt-3 max-w-xs text-sm text-white/60">
          Sightseeing cruises and private hire on the Manchester Ship Canal from Salford Quays.
        </p>
      </div>

      {/* Contact details — NAP sourced from src/data/site.ts (single source of truth) */}
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-wider text-white">Contact</h2>
        <address class="mt-4 space-y-2 text-sm not-italic text-white/60">
          <p>{site.addressDisplay}</p>
          <p>
            <a href={`mailto:${site.email}`} class="transition-colors hover:text-white">
              {site.email}
            </a>
          </p>
          <p>
            <a href={site.phoneHref} class="transition-colors hover:text-white">{site.phone}</a>
          </p>
        </address>
      </div>

      {/* Social links + Manage My Booking */}
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-wider text-white">Follow us</h2>
        <ul class="mt-4 flex flex-wrap gap-4 text-sm">
          {
            social.map((s) => (
              <li>
                <a
                  href={s.href}
                  class="text-white/60 transition-colors hover:text-white"
                  aria-label={`${s.label} (link TBC)`}
                >
                  {s.label}
                </a>
              </li>
            ))
          }
        </ul>
        <div class="mt-6 flex flex-col items-start gap-3 text-sm font-medium">
          <a href="/discover" class="text-accent transition-colors hover:underline">Discover</a>
          <a href="/manage-booking" class="text-accent transition-colors hover:underline">Manage My Booking</a>
        </div>
      </div>
    </div>

    <div class="mt-10 border-t border-white/10 pt-6 text-xs text-white/60">
      <p>&copy; {year} Manchester River Cruises. All rights reserved.</p>
    </div>
  </div>
</footer>
