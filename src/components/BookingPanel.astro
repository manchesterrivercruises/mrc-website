---
import BookDirect, { BOOK_DIRECT_POINTS } from './BookDirect.astro';

// Booking panel: price, Ventrata widget placeholder, and "book direct" reassurance.
// The reassurance copy comes from the shared BookDirect component (single source).
interface Props {
  price: string;
  priceSuffix?: string;
  priceNote?: string;
  bookDirect?: string[];
  manageBookingHref?: string;
}
const {
  price,
  priceSuffix = 'per person',
  priceNote,
  bookDirect = BOOK_DIRECT_POINTS,
  manageBookingHref = '/manage-booking',
} = Astro.props;
---

<div class="rounded-card bg-white p-6 shadow-xl ring-1 ring-black/5">
  <div class="flex items-baseline justify-between">
    <span class="text-sm text-subtle">From</span>
    <span class="text-3xl font-bold text-ink">
      {price}<span class="ml-1 text-sm font-normal text-subtle">{priceSuffix}</span>
    </span>
  </div>
  {priceNote && <p class="mt-1 text-sm text-subtle">{priceNote}</p>}

  {/* Booking widget — pages inject the real widget via the "widget" slot;
      the placeholder below is the fallback when no widget is provided. */}
  <div class="mt-5">
    <slot name="widget">
      <div
        class="flex min-h-44 items-center justify-center rounded-card border border-dashed border-black/15 bg-panel p-6 text-center text-sm text-subtle"
      >
        Live availability &amp; booking widget will appear here.
      </div>
    </slot>
  </div>

  <h3 class="mt-6 text-sm font-semibold text-ink">Why book direct?</h3>
  <BookDirect points={bookDirect} manageBookingHref={manageBookingHref} class="mt-3 text-sm" />
</div>
