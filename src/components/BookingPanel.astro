---
// Booking panel: price, Ventrata widget placeholder, and "book direct" reassurance.
interface Props {
  price: string;
  priceSuffix?: string;
  priceNote?: string;
  bookDirect?: string[];
  manageBookingHref?: string;
}
const {
  price,
  priceSuffix = 'per person',
  priceNote,
  bookDirect = [],
  manageBookingHref = '/manage-booking',
} = Astro.props;
---

<div class="rounded-card bg-white p-6 shadow-xl ring-1 ring-black/5">
  <div class="flex items-baseline justify-between">
    <span class="text-sm text-subtle">From</span>
    <span class="text-3xl font-bold text-ink">
      {price}<span class="ml-1 text-sm font-normal text-subtle">{priceSuffix}</span>
    </span>
  </div>
  {priceNote && <p class="mt-1 text-sm text-subtle">{priceNote}</p>}

  {/* Ventrata embedded widget placeholder — integration handled in a later step. */}
  <div
    class="mt-5 flex min-h-44 items-center justify-center rounded-card border border-dashed border-black/15 bg-panel p-6 text-center text-sm text-subtle"
  >
    Live availability &amp; booking widget will appear here.
  </div>

  <h3 class="mt-6 text-sm font-semibold text-ink">Why book direct?</h3>
  <ul class="mt-3 space-y-2">
    {
      bookDirect.map((point) => (
        <li class="flex gap-2 text-sm text-body">
          <span aria-hidden="true" class="mt-0.5 flex-none text-primary">
            ✓
          </span>
          <span>{point}</span>
        </li>
      ))
    }
    <li class="flex gap-2 text-sm text-body">
      <span aria-hidden="true" class="mt-0.5 flex-none text-primary">✓</span>
      <a href={manageBookingHref} class="font-medium text-primary hover:underline">Manage My Booking</a>
    </li>
  </ul>
</div>
