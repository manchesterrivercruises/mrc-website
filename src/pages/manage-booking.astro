---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
import SectionHeading from '../components/SectionHeading.astro';
import CTAButton from '../components/CTAButton.astro';
import VentrataWidget from '../components/VentrataWidget.astro';

const SITE = site.url;
const pageTitle = 'Manage My Booking — Manchester River Cruises';
const pageDescription =
  'Find your Manchester River Cruises booking to view the details and resend your confirmation. ' +
  "You'll need your booking reference and the email address used when booking.";

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Manage My Booking',
  description: pageDescription,
  url: `${SITE}/manage-booking`,
};

// Self-service capabilities the reservation flow actually exposes are TBC against Ventrata's
// openReservationFlow on device (see VentrataWidget → SELF-SERVICE FLOWS). Copy below stays
// deliberately conservative — "view details / resend confirmation" is the safe floor; amend/cancel
// self-service is TBC and marked as such rather than promised. Confirm on-device, then tighten.
const selfService = [
  'View your booking details — date, time, guest numbers and boarding point.',
  'Resend your booking confirmation to the email address on the booking. (TBC)',
  'Amend your booking where the tour and timing allow it. (TBC — depends on what Ventrata’s reservation flow permits for this account)',
];

// "Needs a call" — mirrors existing policy copy in /faq (weather, cancellation, groups). Kept as the
// human-handled path because these aren’t reliably self-service and some carry a judgement call.
const needsACall = [
  {
    title: 'Weather cancellations',
    body: 'Cruises run in most weather — the boat has a heated indoor cabin. If we ever have to cancel for conditions on the water, we’ll contact you directly; call us if you’re unsure before you travel. (TBC)',
  },
  {
    title: 'Group & large-party changes',
    body: 'Changes to group bookings and larger parties are handled by our team so we can keep seating and boarding right for everyone. (TBC)',
  },
  {
    title: 'Cancellations & refunds',
    body: 'Free cancellation up to 24 hours before departure. For anything inside that window, or if you’re not sure what your booking allows, give us a call. (Full policy TBC.)',
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  {/* Schema.org structured data (WebPage) */}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

  <section class="mx-auto max-w-2xl px-4 py-16 sm:px-6 md:py-20">
    <h1 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">Manage my booking</h1>
    <p class="mt-4 text-lg leading-relaxed text-body">
      Already booked? Find your reservation to check the details and resend your confirmation.
      You’ll need your <strong class="font-semibold text-ink">booking reference</strong> and the
      <strong class="font-semibold text-ink">email address</strong> you booked with.
    </p>

    {/* PRIMARY CTA — opens Ventrata's self-service reservation flow (openReservationFlow) directly,
        no productID. Exact config is TBC on device; see VentrataWidget SELF-SERVICE FLOWS block. */}
    <div class="mt-8">
      <VentrataWidget mode="popup" reservation label="Find my booking" class="w-full sm:w-auto" />
    </div>

    {/* What you can do here */}
    <div class="mt-12">
      <SectionHeading as="h2">What you can do here</SectionHeading>
      <ul class="mt-4 space-y-3 text-body">
        {
          selfService.map((item) => (
            <li class="flex gap-3">
              <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-primary" aria-hidden="true" />
              <span class="leading-relaxed">{item}</span>
            </li>
          ))
        }
      </ul>
    </div>

    {/* What needs a call */}
    <div class="mt-12">
      <SectionHeading as="h2">Things to call us about</SectionHeading>
      <p class="mt-4 text-body">
        Some changes are quicker with a human. Get in touch for any of these and we’ll sort it.
      </p>
      <dl class="mt-6 space-y-5">
        {
          needsACall.map((n) => (
            <div class="rounded-card bg-panel p-5 ring-1 ring-black/5">
              <dt class="font-semibold text-ink">{n.title}</dt>
              <dd class="mt-1.5 text-sm leading-relaxed text-body">{n.body}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    {/* Contact fallback */}
    <div class="mt-12 rounded-card bg-panel p-6 ring-1 ring-black/5">
      <SectionHeading as="h2">Can’t find your booking?</SectionHeading>
      <p class="mt-4 text-body">
        If your reference isn’t recognised, check it against your confirmation email — then our team
        is happy to help.
      </p>
      <address class="mt-3 space-y-1 text-sm not-italic text-body">
        <p>
          <a href={`mailto:${site.email}`} class="font-medium text-primary hover:underline">
            {site.email}
          </a>
        </p>
        <p>
          <a href={site.phoneHref} class="font-medium text-primary hover:underline">
            {site.phone}
          </a>
        </p>
      </address>
      <div class="mt-5">
        <CTAButton href="/faq" variant="outline">Read our FAQ</CTAButton>
      </div>
    </div>
  </section>
</BaseLayout>
