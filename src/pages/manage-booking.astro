---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
import SectionHeading from '../components/SectionHeading.astro';
import CTAButton from '../components/CTAButton.astro';

const SITE = site.url;
const pageTitle = 'Manage My Booking — Manchester River Cruises';
const pageDescription =
  "View, amend or cancel your Manchester River Cruises booking online. You'll need your booking reference and the email address used when booking.";

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Manage My Booking',
  description: pageDescription,
  url: `${SITE}/manage-booking`,
};
---

<BaseLayout title={pageTitle} description={pageDescription}>
  {/* Schema.org structured data (WebPage) */}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

  <section class="mx-auto max-w-2xl px-4 py-16 sm:px-6 md:py-20">
    <h1 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">Manage My Booking</h1>
    <p class="mt-4 text-lg leading-relaxed text-body">
      View, amend or cancel your Manchester River Cruises booking. You'll need your booking
      reference and the email address used when booking.
    </p>

    {/* Ventrata Manage My Booking widget — PLACEHOLDER only.
        The live embed mirrors the checkout widget: it uses the SAME Ventrata checkout script
        (cdn.checkout.ventrata.com) plus a container element. Script wired in a later step. */}
    <div
      class="mt-8 flex min-h-80 items-center justify-center rounded-card border border-dashed border-black/15 bg-panel p-8 text-center text-sm text-subtle"
    >
      The Manage My Booking portal will load here.
    </div>

    {/* Help section */}
    <div class="mt-12 rounded-card bg-panel p-6 ring-1 ring-black/5">
      <SectionHeading as="h2">Need help?</SectionHeading>
      <p class="mt-4 text-body">
        If you're having trouble finding your booking, our team is happy to help.
      </p>
      <address class="mt-3 space-y-1 text-sm not-italic text-body">
        <p>
          <a href="mailto:info@manchesterrivercruises.com" class="font-medium text-primary hover:underline">
            info@manchesterrivercruises.com
          </a>
        </p>
        <p>Phone number TBC</p>
      </address>
      <div class="mt-5">
        <CTAButton href="/faq" variant="outline">Read our FAQ</CTAButton>
      </div>
    </div>
  </section>
</BaseLayout>
