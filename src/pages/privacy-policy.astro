---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { site } from '../data/site';

const pageTitle = 'Privacy Policy — Manchester River Cruises';
const pageDescription =
  'How Manchester River Cruises collects, uses and protects your personal data — enquiry forms, bookings, analytics and your rights under UK GDPR.';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Privacy Policy',
  description: pageDescription,
  url: `${site.url}/privacy-policy`,
};

const heading = 'text-lg font-semibold text-ink';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 md:py-20 lg:px-8">
    <h1 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">Privacy Policy</h1>

    {/* Legal-review note */}
    <div class="mt-6 rounded-card bg-panel p-4 text-sm leading-relaxed text-body ring-1 ring-black/5">
      <strong class="text-ink">Draft — pending legal review (TBC).</strong> This policy is a working
      draft describing our intended data practices. It has not yet been reviewed by a solicitor and
      may change before launch. Specific retention periods and third-party terms are still to be
      confirmed.
    </div>

    <div class="mt-10 space-y-10 leading-relaxed text-body">
      <section>
        <p>
          This policy explains how Manchester River Cruises ("we", "us") collects and uses your
          personal data, and your rights under UK data protection law (UK GDPR and the Data
          Protection Act 2018). We are the data controller for the personal data described below.
        </p>
      </section>

      <section aria-labelledby="forms">
        <SectionHeading id="forms" as="h2">Enquiry &amp; contact forms</SectionHeading>
        <p class="mt-4">
          When you submit our contact or private hire enquiry forms we collect the details you
          provide (such as your name, email, phone number and message). Our forms are handled by
          <strong>Netlify Forms</strong> (our hosting provider), which stores the submissions and
          forwards them to us by email so we can respond. We use this data only to reply to and
          manage your enquiry. Lawful basis: your consent / our legitimate interest in responding to
          you. Retention period: TBC.
        </p>
      </section>

      <section aria-labelledby="bookings">
        <SectionHeading id="bookings" as="h2">Bookings</SectionHeading>
        <p class="mt-4">
          Bookings and payments are taken through <strong>Ventrata</strong>, our booking and
          checkout platform, which acts as a data processor on our behalf (and handles payment
          securely via its own payment providers). The booking details you enter go to Ventrata to
          fulfil your booking; we do not store your full payment card details. Ventrata's own
          processing is governed by its terms and privacy notice. Lawful basis: performance of a
          contract.
        </p>
      </section>

      <section aria-labelledby="analytics">
        <SectionHeading id="analytics" as="h2">Analytics &amp; cookies</SectionHeading>
        <p class="mt-4">
          We intend to use <strong>Google Tag Manager</strong> to manage analytics and marketing
          tags, including <strong>Google Analytics 4</strong> and the <strong>Meta (Facebook)
          Pixel</strong>, to understand how the site is used and to measure our advertising. These
          set cookies and similar technologies.
        </p>
        <p class="mt-4">
          <strong>Consent:</strong> a cookie-consent mechanism is still to be implemented. Non-essential
          analytics and marketing tags will not run until you have given consent, and you will be able
          to change your choice at any time. (Implementation pending — see our launch checklist.)
        </p>
      </section>

      <section aria-labelledby="marketing">
        <SectionHeading id="marketing" as="h2">Email marketing</SectionHeading>
        <p class="mt-4">
          If you sign up to our newsletter or opt in during booking, we use <strong>Klaviyo</strong>
          to send marketing emails (such as offers, event announcements and pre-cruise reminders).
          You can unsubscribe at any time using the link in any email. Lawful basis: your consent.
        </p>
      </section>

      <section aria-labelledby="sharing">
        <SectionHeading id="sharing" as="h2">Who we share data with</SectionHeading>
        <p class="mt-4">
          We share personal data only with the processors that run our services — currently Netlify
          (hosting and forms), Ventrata (bookings), Google (analytics/tag management), Meta
          (advertising) and Klaviyo (email marketing) — and where required by law. We do not sell
          your personal data.
        </p>
      </section>

      <section aria-labelledby="rights">
        <SectionHeading id="rights" as="h2">Your rights</SectionHeading>
        <p class="mt-4">Under UK GDPR you have the right to:</p>
        <ul class="mt-3 list-disc space-y-1 pl-6">
          <li>access the personal data we hold about you;</li>
          <li>ask us to correct inaccurate or incomplete data;</li>
          <li>ask us to erase your data ("right to be forgotten");</li>
          <li>restrict or object to our processing, including for direct marketing;</li>
          <li>data portability, where applicable; and</li>
          <li>withdraw consent at any time, where processing is based on consent.</li>
        </ul>
        <p class="mt-4">
          To exercise any of these rights, contact us using the details below. You also have the
          right to complain to the UK's Information Commissioner's Office (ICO) at
          <a href="https://ico.org.uk" rel="noopener" target="_blank" class="font-medium text-primary hover:underline">ico.org.uk</a>.
        </p>
      </section>

      <section aria-labelledby="contact">
        <SectionHeading id="contact" as="h2">Contact us</SectionHeading>
        <div class="mt-4 space-y-1">
          <p class={heading}>{site.name}</p>
          <p>{site.addressDisplay}</p>
          <p>
            Email:
            <a href={`mailto:${site.email}`} class="font-medium text-primary hover:underline">{site.email}</a>
          </p>
          <p>
            Phone:
            <a href={site.phoneHref} class="font-medium text-primary hover:underline">{site.phone}</a>
          </p>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
