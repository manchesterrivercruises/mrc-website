---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../data/site';
import ProductCard from '../../components/ProductCard.astro';

// Discover hub — lists every published guide from the `discover` collection,
// newest first. Cards and content both come from the collection, not hardcoded.
const guides = (await getCollection('discover', ({ data }) => !data.draft)).sort(
  (a, b) => (b.data.publishDate?.getTime() ?? 0) - (a.data.publishDate?.getTime() ?? 0)
);

const SITE = site.url;
const pageTitle = 'Discover — Manchester River Cruises';
const pageDescription =
  'Guides to Salford Quays, Old Trafford, The Lowry, IWM North and the Manchester Ship Canal — ideas for a great day out on and around the water.';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Discover',
  description: pageDescription,
  url: `${SITE}/discover`,
  hasPart: guides.map((g) => ({
    '@type': 'Article',
    headline: g.data.title,
    url: `${SITE}/discover/${g.id}`,
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription}>
  {/* Schema.org structured data (CollectionPage) */}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

  <div>
    {/* Hero — dark navy, gold accents */}
    <section class="bg-dark text-white">
      <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 md:py-24 lg:px-8">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-accent">Ideas & guides</p>
        <h1 class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl md:text-6xl">Discover</h1>
        <p class="mt-5 max-w-2xl text-lg leading-relaxed text-white/80">
          Guides, ideas and inspiration for a great day out on and around the Manchester Ship Canal.
        </p>
      </div>
    </section>

    {/* Guide grid */}
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 md:py-16 lg:px-8">
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          guides.map((g) => (
            <ProductCard
              name={g.data.title}
              desc={g.data.description}
              href={`/discover/${g.id}`}
              linkText="Read guide"
              imageLabel={g.data.heroImageAlt ?? 'Image (TBC)'}
            />
          ))
        }
      </div>
    </div>
  </div>
</BaseLayout>
