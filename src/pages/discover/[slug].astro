---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ProductCard from '../../components/ProductCard.astro';

// One page per Discover guide, generated from the `discover` content collection.
// Content lives in src/content/discover/*.md — layout stays here in the template.
export async function getStaticPaths() {
  const guides = await getCollection('discover', ({ data }) => !data.draft);
  return guides.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, heroImageAlt, publishDate } = entry.data;

const SITE = 'https://www.manchesterrivercruises.com';
const pageTitle = `${title} — Manchester River Cruises`;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: `${SITE}/discover/${entry.id}`,
  ...(publishDate ? { datePublished: publishDate.toISOString() } : {}),
  author: { '@type': 'Organization', name: 'Manchester River Cruises', url: SITE },
  publisher: { '@type': 'Organization', name: 'Manchester River Cruises', url: SITE },
};
---

<BaseLayout title={pageTitle} description={description} ogType="article">
  {/* Schema.org structured data (Article) */}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6 md:py-16 lg:px-8">
    {/* Article header */}
    <header>
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Discover</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-ink sm:text-5xl">{title}</h1>
      <p class="mt-4 text-lg leading-relaxed text-subtle">{description}</p>
    </header>

    {/* Hero image placeholder — swap for a real asset via the collection's heroImage field */}
    <div class="mt-8 flex aspect-[16/9] items-center justify-center rounded-card bg-panel text-xs text-subtle">
      {heroImageAlt ?? 'Image (TBC)'}
    </div>

    {/* Markdown body */}
    <div class="article-body mt-10">
      <Content />
    </div>

    {/* Cross-sell to City River Tour */}
    <section aria-labelledby="also" class="mt-16">
      <SectionHeading id="also">See it from the water</SectionHeading>
      <div class="mt-8 sm:max-w-sm">
        <ProductCard
          name="City River Tour"
          desc="Our signature 60-minute sightseeing cruise along the Manchester Ship Canal from Salford Quays."
          href="/city-river-tour"
        />
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  /* Prose styling for the rendered markdown. Kept scoped to the template so content
     stays layout-free (no Tailwind Typography plugin — avoids a new dependency). */
  .article-body {
    color: var(--color-body);
    font-size: 1.0625rem;
    line-height: 1.75;
  }
  .article-body :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-ink);
  }
  .article-body :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-ink);
  }
  .article-body :global(p) {
    margin-bottom: 1.25rem;
  }
  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 1.25rem 0;
    padding-left: 1.5rem;
  }
  .article-body :global(ul) {
    list-style: disc;
  }
  .article-body :global(ol) {
    list-style: decimal;
  }
  .article-body :global(li) {
    margin-bottom: 0.5rem;
  }
  .article-body :global(li)::marker {
    color: var(--color-accent);
  }
  .article-body :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .article-body :global(strong) {
    font-weight: 600;
    color: var(--color-ink);
  }
</style>
