---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTAButton from '../components/CTAButton.astro';
import FAQSection from '../components/FAQSection.astro';
import GettingHere from '../components/GettingHere.astro';
import KeyFacts from '../components/KeyFacts.astro';
import ProductCard from '../components/ProductCard.astro';

const icons = {
  sparkles:
    '<path d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" /><path d="M18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z" />',
  pin: '<path d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />',
  cake: '<path d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.87c1.355 0 2.697.055 4.024.165C17.155 8.51 18 9.473 18 10.608v2.513m-3-4.87v-1.5m-6 1.5v-1.5m12 9.75-1.5.75a3.354 3.354 0 0 1-3 0 3.354 3.354 0 0 0-3 0 3.354 3.354 0 0 1-3 0 3.354 3.354 0 0 0-3 0 3.354 3.354 0 0 1-3 0L3 16.5m15-3.38a48.474 48.474 0 0 0-6-.37c-2.032 0-4.034.126-6 .37m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.17c0 .62-.504 1.124-1.125 1.124H4.125A1.125 1.125 0 0 1 3 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 0 1 6 13.12" />',
  users:
    '<path d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />',
};

const keyFacts = [
  { text: 'Exclusive whole-boat charter', icon: icons.sparkles },
  { text: 'Departs Salford Quays', icon: icons.pin },
  { text: 'Catering available', icon: icons.cake },
  { text: 'Groups up to TBC', icon: icons.users },
];

const occasions = [
  {
    title: 'Birthdays',
    body: 'Mark a milestone birthday afloat, with the whole boat to yourselves and the Manchester skyline as your backdrop.',
  },
  {
    title: 'Hen & stag parties',
    body: 'A private charter is a memorable start to the celebrations — space to relax, drinks at the licensed bar and no queues.',
  },
  {
    title: 'Corporate away days',
    body: 'Reward the team or entertain clients with an away day on the water — a relaxed setting for socialising or informal meetings.',
  },
  {
    title: 'Weddings',
    body: 'From an intimate ceremony to a post-wedding celebration, hire a boat exclusively for your day on the Ship Canal.',
  },
  {
    title: 'Private dining',
    body: 'Combine the cruise with catering for a private dining experience — details tailored to your group (options TBC).',
  },
  {
    title: 'Filming & photography',
    body: 'A distinctive, controllable location on the water for productions, shoots and brand launches.',
  },
];

const steps = [
  { n: '1', title: 'Enquire', body: 'Tell us your date, group size and what you have in mind using our private hire enquiry form.' },
  { n: '2', title: 'We plan it with you', body: 'Our team works with you on timings, catering, the route and any extras to suit the occasion.' },
  { n: '3', title: 'Set sail', body: 'Arrive at Salford Quays, step aboard and enjoy the whole boat, exclusively yours.' },
];

const faqs = [
  { q: 'How much does private boat hire in Manchester cost?', a: 'Pricing depends on the vessel, group size, duration and any catering or extras. Full pricing guide TBC — enquire for a tailored quote.' },
  { q: 'What group sizes can you accommodate?', a: 'From smaller private groups up to larger parties, depending on the vessel. Exact capacities TBC — see our vessels page.' },
  { q: 'Is catering available?', a: 'Yes — a range of catering options can be arranged to suit your event. Menus and options TBC.' },
  { q: 'How long is a private charter?', a: 'Charter durations are flexible and agreed when you book. Minimum hire duration TBC.' },
  { q: 'What routes are available?', a: 'Charters run on the Manchester Ship Canal from Salford Quays; route options are discussed when we plan your event. (TBC)' },
];

const SITE = 'https://www.manchesterrivercruises.com';
const pageTitle = 'Private Boat Hire Manchester — Charter a Boat on the Ship Canal';
const pageDescription =
  'Private boat hire in Manchester — charter a boat exclusively on the Manchester Ship Canal for birthdays, weddings, corporate away days, private dining and filming. Departs Salford Quays. Enquire today.';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      name: 'Private Boat Hire Manchester',
      description: pageDescription,
      serviceType: 'Private boat hire',
      areaServed: 'Manchester',
      url: `${SITE}/private-boat-hire-manchester`,
      provider: { '@type': 'LocalBusiness', name: 'Manchester River Cruises', url: SITE },
    },
    {
      '@type': 'LocalBusiness',
      name: 'Manchester River Cruises',
      url: SITE,
      email: 'info@manchesterrivercruises.com',
      address: { '@type': 'PostalAddress', streetAddress: 'Millennium Footbridge, The Quays', addressLocality: 'Salford', postalCode: 'M50 3RB', addressCountry: 'GB' },
      geo: { '@type': 'GeoCoordinates', latitude: 53.4705, longitude: -2.296 },
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription}>
  {/* Schema.org structured data (Service + LocalBusiness) */}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

  <div>
    {/* Hero — dark navy, gold accents */}
    <section class="bg-dark text-white">
      <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 md:py-28 lg:px-8">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-accent">Private charter</p>
        <h1 class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl md:text-6xl">Private Boat Hire Manchester</h1>
        <p class="mt-5 max-w-2xl text-lg leading-relaxed text-white/80">
          Charter a boat on the Manchester Ship Canal for your celebration or event.
        </p>
        <div class="mt-8">
          <CTAButton href="/private-hire">Make an enquiry</CTAButton>
        </div>
      </div>
    </section>

    <KeyFacts facts={keyFacts} />

    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 md:py-16 lg:px-8">
      <div class="space-y-16">
        {/* Intro — SEO-rich */}
        <section aria-labelledby="intro">
          <SectionHeading id="intro">Charter a private boat in Manchester</SectionHeading>
          <div class="mt-6 max-w-3xl space-y-4 text-lg leading-relaxed text-body">
            <p>
              Private boat hire in Manchester gives you exclusive use of a whole vessel on the
              Manchester Ship Canal — a striking, memorable setting for any occasion. Whether you're
              planning a birthday, a hen or stag party, a corporate away day or a wedding, chartering
              a boat puts you and your guests centre stage, gliding past Salford Quays, MediaCity and
              the city's waterfront landmarks.
            </p>
            <p>
              Every charter is tailored around you. Our team helps you shape the experience — from
              departure time and duration to catering and the route — so the day runs exactly as you
              want it. Cruises depart from our Salford Quays base, with a licensed bar onboard and an
              experienced crew looking after every detail.
            </p>
            <p class="text-base text-subtle">Full pricing, capacities and route options — TBC from Simon (content-checklist.md).</p>
          </div>
        </section>

        {/* Occasions grid */}
        <section aria-labelledby="occasions">
          <SectionHeading id="occasions">Perfect for every occasion</SectionHeading>
          <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {
              occasions.map((o) => (
                <article class="rounded-card bg-panel p-6 ring-1 ring-black/5">
                  <h3 class="text-lg font-semibold text-ink">{o.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-body">{o.body}</p>
                </article>
              ))
            }
          </div>
        </section>

        {/* How it works */}
        <section aria-labelledby="how">
          <SectionHeading id="how">How it works</SectionHeading>
          <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-3">
            {
              steps.map((s) => (
                <div class="flex flex-col">
                  <span
                    aria-hidden="true"
                    class="flex h-10 w-10 flex-none items-center justify-center rounded-full bg-accent font-bold text-dark"
                  >
                    {s.n}
                  </span>
                  <h3 class="mt-4 text-lg font-semibold text-ink">{s.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-body">{s.body}</p>
                </div>
              ))
            }
          </div>
        </section>

        {/* Vessels */}
        <section aria-labelledby="vessels">
          <SectionHeading id="vessels">Our vessels</SectionHeading>
          <div class="mt-6 max-w-3xl space-y-4 text-lg leading-relaxed text-body">
            <p>
              Our fleet offers a range of vessels for private charter, each with its own character and
              capacity. Take a look at the boats available and find the right fit for your group.
            </p>
          </div>
          <div class="mt-6">
            <CTAButton href="/vessels" variant="outline">View our fleet</CTAButton>
          </div>
        </section>

        {/* Strong CTA — this page sells, /private-hire converts */}
        <section aria-labelledby="cta">
          <div class="rounded-card bg-dark p-8 text-white sm:p-10">
            <h2 id="cta" class="text-2xl font-bold tracking-tight sm:text-3xl">Ready to charter your boat?</h2>
            <p class="mt-3 max-w-2xl text-lg leading-relaxed text-white/80">
              Tell us about your event and our team will put together a tailored private hire quote.
            </p>
            <div class="mt-6">
              <CTAButton href="/private-hire">Make an enquiry</CTAButton>
            </div>
          </div>
        </section>

        <FAQSection faqs={faqs} title="Private boat hire FAQs" />

        {/* Cross-sell to City River Tour */}
        <section aria-labelledby="also">
          <SectionHeading id="also">Prefer a scheduled cruise?</SectionHeading>
          <div class="mt-8 sm:max-w-sm">
            <ProductCard name="City River Tour" desc="Our signature 60-minute sightseeing cruise along the Manchester Ship Canal." href="/city-river-tour" />
          </div>
        </section>

        <GettingHere />
      </div>
    </div>
  </div>
</BaseLayout>
