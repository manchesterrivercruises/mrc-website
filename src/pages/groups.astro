---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
import PageHero from '../components/PageHero.astro';
import KeyFacts from '../components/KeyFacts.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTAButton from '../components/CTAButton.astro';
import CTASection from '../components/CTASection.astro';
import FAQSection from '../components/FAQSection.astro';
import GettingHere from '../components/GettingHere.astro';

// Group Visits, School Trips & Coach Parties landing page.
// Three audience sections (group bookings 10+, schools & youth, coach parties/trade),
// a schema-emitting FAQ block, and cross-links to the City River Tour + private-hire
// enquiry. Every unconfirmed operational claim carries a visible (TBC) marker for
// Simon's content pass (content-checklist.md). School section is deliberately kept
// alcohol-free / school-safe.

const icons = {
  users:
    '<path d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />',
  academic:
    '<path d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />',
  bus: '<path d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.66-.837H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />',
  pin: '<path d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />',
};

const keyFacts = [
  { text: 'Groups of 10+ welcome', icon: icons.users },
  { text: 'School & youth charters', icon: icons.academic },
  { text: 'Coach parties & the trade', icon: icons.bus },
  { text: 'Salford Quays departure', icon: icons.pin },
];

// Three audience sections — each with its own copy, benefits card and CTA.
const audiences = [
  {
    id: 'group-bookings',
    eyebrow: 'Group bookings',
    title: 'Group bookings (10+)',
    copy: [
      'Bringing a group of ten or more? There are two easy ways aboard. Join a scheduled public sailing of our City River Tour at a group rate, or take a private charter of the whole boat for complete flexibility over your date, timings and route.',
      'Public sailings are the simplest option for social clubs, societies, work outings and celebrations — we reserve space for your party together on a set departure. For full control, a private charter makes the vessel exclusively yours.',
    ],
    tbc: 'Group discount rate, organiser-goes-free policy and payment terms — TBC from Simon (content-checklist.md).',
    asideTitle: 'Group organiser benefits',
    highlights: [
      'Group rates for parties of 10+ (TBC)',
      'Organiser-goes-free policy (TBC)',
      'Flexible payment terms (TBC)',
      'Public sailing or private charter',
    ],
    cta: { label: 'Enquire about group rates', href: '/contact' },
    secondary: { label: 'View the City River Tour', href: '/city-river-tour' },
  },
  {
    id: 'schools',
    eyebrow: 'Schools & youth groups',
    title: 'School & youth groups',
    copy: [
      'School trips, college groups, scouts, guides and youth organisations sail as a private charter — the whole boat is yours, not a shared public sailing. That means one group, a tailored commentary pitched to your age range, and simple logistics from boarding to disembarking.',
      'The Ship Canal is a floating history lesson: the Industrial Revolution and the age of the docks, the working waterway that built the city, and the MediaCity regeneration that transformed it. It is a hands-on complement to the classroom — geography, history and local studies all on one route.',
    ],
    tbc: 'Risk assessment documentation, teacher planning visits and adult-to-pupil ratio guidance — TBC from Simon (content-checklist.md).',
    asideTitle: 'For teachers & group leaders',
    highlights: [
      'Whole-boat private charter — one group only',
      'Commentary tailored to your age range',
      'Risk assessment documentation on request (TBC)',
      'Teacher planning visit welcome (TBC)',
      'Adult-to-pupil ratio guidance (TBC)',
    ],
    cta: { label: 'Enquire about a school charter', href: '/private-hire#enquire' },
    secondary: null,
  },
  {
    id: 'coach-parties',
    eyebrow: 'Coach parties & tour operators',
    title: 'Coach parties & tour operators',
    copy: [
      'We welcome coach parties and tour operators aboard the City River Tour. Whether you are building a Manchester day out or slotting a river cruise into a wider itinerary, our sightseeing tour is an easy, memorable inclusion — around an hour on the water with live commentary.',
      'Coaches can set down close to the Millennium Footbridge boarding point; we will advise on the nearest drop-off and parking when you book. Pre-booked group rates and invoice payment are available for the trade.',
    ],
    tbc: 'Exact coach drop-off and parking arrangements, driver/courier-goes-free policy, group rates and invoice terms — TBC from Simon (content-checklist.md).',
    asideTitle: 'For coach operators & the trade',
    highlights: [
      'Coach drop-off near the boarding point (TBC)',
      'Parking guidance provided (TBC)',
      'Driver & courier go free (TBC)',
      'Pre-booked group rates (TBC)',
      'Invoice payment available (TBC)',
    ],
    cta: { label: 'Trade & coach enquiries', href: '/contact' },
    secondary: { label: 'View the City River Tour', href: '/city-river-tour' },
  },
];

const faqs = [
  {
    q: 'What is the minimum group size?',
    a: 'Group rates apply to parties of 10 or more on a scheduled City River Tour; school, youth and other private charters take the whole boat. Exact minimums and boat capacity — TBC.',
  },
  {
    q: 'What happens if the weather is bad?',
    a: 'The boat has a heated indoor cabin, so cruises run in most weather. If conditions affect sailing we contact the group organiser to rearrange. Full weather and cancellation policy — TBC.',
  },
  {
    q: 'Are groups accessible for wheelchair users and less mobile guests?',
    a: 'Step-free boarding is available where tides allow, and we will talk through your group’s needs before you sail. Full accessibility details — TBC. See our Accessibility page.',
  },
  {
    q: 'How do deposits and payment work for groups?',
    a: 'Group and charter bookings can be arranged with a deposit and balance, and invoice payment is available for schools and the trade. Deposit amounts and payment terms — TBC.',
  },
  {
    q: 'Can we have a tailored commentary or itinerary?',
    a: 'Yes — private charters (including school and youth groups) can have commentary pitched to the group, and we can talk through timings and route. Confirmed when you book. (TBC)',
  },
  {
    q: 'Do group organisers or drivers go free?',
    a: 'We plan to offer organiser and driver/courier-goes-free arrangements; the exact policy is being confirmed. (TBC)',
  },
];

const SITE = site.url;
const pageTitle = 'Group Visits, School Trips & Coach Parties — Manchester River Cruises';
const pageDescription =
  'Group visits, school trips and coach parties on the Manchester Ship Canal. Group rates on the City River Tour, or a private charter for schools, youth groups and tour operators from Salford Quays. Enquire today.';

// Schema.org: TouristAttraction (the group offer) + LocalBusiness (NAP) + FAQPage
// (built from the visible Q&A above), emitted as one @graph.
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'TouristAttraction',
      name: 'Group Visits, School Trips & Coach Parties — Manchester River Cruises',
      description: pageDescription,
      url: `${SITE}/groups`,
      touristType: ['Groups', 'School trips', 'Coach parties'],
      availableLanguage: 'English',
      address: { '@type': 'PostalAddress', ...site.address },
      geo: { '@type': 'GeoCoordinates', ...site.geo },
    },
    {
      '@type': 'LocalBusiness',
      name: site.name,
      url: SITE,
      email: site.email,
      address: { '@type': 'PostalAddress', ...site.address },
      geo: { '@type': 'GeoCoordinates', ...site.geo },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription}>
  {/* Schema.org structured data (TouristAttraction + LocalBusiness + FAQPage) */}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

  <div>
    {/* Hero — owned fleet/deck imagery behind the navy overlay */}
    <PageHero
      eyebrow="Group visits, schools & coach parties"
      title="Group Visits, School Trips & Coach Parties"
      subtitle="Bring a group aboard the Manchester Ship Canal. Group rates on the City River Tour, or a private charter for schools, youth groups and the coach trade — all from Salford Quays."
      heroImage="/images/city-river-tour-hero.webp"
      heroImageAlt="A Manchester River Cruises vessel on the Ship Canal at Salford Quays"
    >
      <CTAButton href="/contact">Enquire about a group visit</CTAButton>
      <CTAButton href="/whats-on" variant="outline">See What's On</CTAButton>
    </PageHero>

    {/* Key facts strip */}
    <KeyFacts facts={keyFacts} />

    {/* Intro */}
    <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 md:py-12 lg:px-8">
      <section aria-labelledby="about">
        <SectionHeading id="about">Three ways to bring a group aboard</SectionHeading>
        <div class="mt-6 max-w-3xl space-y-4 text-lg leading-relaxed text-body">
          <p>
            Whether you are organising a social club outing, a school trip or a coach tour, there is a
            simple way aboard: join a scheduled City River Tour at a <strong>group rate</strong>, or take
            the whole boat with a <strong>private charter</strong> for full flexibility.
          </p>
          <p class="text-base text-subtle">
            Full group, school and trade details — TBC from Simon (content-checklist.md).
          </p>
        </div>
      </section>
    </div>

    {/* Three audience sections */}
    <div class="mx-auto max-w-6xl px-4 pb-10 sm:px-6 md:pb-12 lg:px-8">
      <div class="space-y-12 md:space-y-16">
        {
          audiences.map((a) => (
            <section id={a.id} aria-labelledby={`${a.id}-heading`}>
              <div class="grid gap-8 lg:grid-cols-[1.4fr_1fr] lg:items-start lg:gap-12">
                <div>
                  <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">{a.eyebrow}</p>
                  <SectionHeading id={`${a.id}-heading`}>{a.title}</SectionHeading>
                  <div class="mt-6 space-y-4 text-lg leading-relaxed text-body">
                    {a.copy.map((p) => (
                      <p>{p}</p>
                    ))}
                    <p class="text-base text-subtle">{a.tbc}</p>
                  </div>
                  <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-3">
                    <CTAButton href={a.cta.href}>{a.cta.label}</CTAButton>
                    {a.secondary && (
                      <a
                        href={a.secondary.href}
                        class="text-sm font-medium text-primary underline-offset-4 hover:underline"
                      >
                        {a.secondary.label} →
                      </a>
                    )}
                  </div>
                </div>
                <div class="rounded-card bg-panel p-6 ring-1 ring-black/5">
                  <h3 class="text-sm font-semibold uppercase tracking-wider text-subtle">{a.asideTitle}</h3>
                  <ul class="mt-4 space-y-3">
                    {a.highlights.map((h) => (
                      <li class="flex gap-3 text-body">
                        <span aria-hidden="true" class="mt-0.5 flex-none text-primary">
                          ✓
                        </span>
                        <span>{h}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </section>
          ))
        }
      </div>
    </div>

    {/* Enquiry CTA band */}
    <CTASection
      heading="Planning a group visit?"
      text="Tell us your group size, preferred date and what you have in mind — a social outing, a school trip or a coach tour — and we will help you choose between a group rate on a public sailing and a private charter."
      primaryHref="/contact"
      primaryLabel="Enquire about a group visit"
      secondaryHref="/whats-on"
      secondaryLabel="See What's On"
    />

    {/* FAQ (schema emitted above) + Getting Here */}
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 md:py-16 lg:px-8">
      <div class="space-y-12 md:space-y-16">
        <FAQSection faqs={faqs} title="Group visits FAQs" />
        <GettingHere />
      </div>
    </div>
  </div>
</BaseLayout>
