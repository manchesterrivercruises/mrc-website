---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../data/site';
import GalleryAlbumGrid from '../../components/GalleryAlbumGrid.astro';
import GalleryLightbox from '../../components/GalleryLightbox.astro';
import GalleryBookingCTA from '../../components/GalleryBookingCTA.astro';
import RelatedAlbums from '../../components/RelatedAlbums.astro';
import { getAlbums, resolveRelated } from '../../lib/gallery';

// One page per album, generated from the `gallery` collection (routed by data.slug).
export async function getStaticPaths() {
  const albums = await getAlbums();
  return albums.map((album) => ({
    params: { slug: album.data.slug },
    props: { album, related: resolveRelated(album, albums) },
  }));
}

const { album, related } = Astro.props;
const d = album.data;

const SITE = site.url;
const abs = (p: string) => new URL(p, SITE).href;

// seoTitle/seoDescription drive the meta, falling back to sensible defaults.
const pageTitle = d.seoTitle ?? `${d.title} — Gallery — Manchester River Cruises`;
const pageDescription = d.seoDescription ?? d.summary;

// Home > Gallery > [album] — drives the BreadcrumbList schema in BaseLayout.
const breadcrumbs = [
  { name: 'Home', url: abs('/') },
  { name: 'Gallery', url: abs('/gallery') },
  { name: d.title, url: abs(`/gallery/${d.slug}`) },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: d.title,
  description: d.summary,
  url: abs(`/gallery/${d.slug}`),
  // Image srcs are placeholder paths until the image() pipeline lands; they resolve to
  // real files then (docs/image-conventions.md).
  image: d.images.map((img) => abs(img.src)),
};
---

<BaseLayout title={pageTitle} description={pageDescription} breadcrumbs={breadcrumbs}>
  {/* Schema.org structured data (ImageGallery) */}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

  <div>
    {/* Hero — dark navy, with a visible breadcrumb trail */}
    <section class="bg-dark text-white">
      <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 md:py-20 lg:px-8">
        <nav aria-label="Breadcrumb" class="text-sm text-white/60">
          <a href="/gallery" class="transition-colors hover:text-white">Gallery</a>
          <span aria-hidden="true" class="px-1">/</span>
          <span class="text-white/90">{d.title}</span>
        </nav>
        <h1 class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl">{d.title}</h1>
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-white/80">{d.summary}</p>
      </div>
    </section>

    {/* Thumbnails (full-size loads on lightbox open) */}
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 md:py-16 lg:px-8">
      <GalleryAlbumGrid album={album} />
    </div>

    {/* PhotoSwipe wiring — bundled only on album pages */}
    <GalleryLightbox />

    {/* Commercial cross-link */}
    <GalleryBookingCTA label={d.bookingCtaLabel} url={d.bookingCtaUrl} albumTitle={d.title} />

    {/* Related albums */}
    <RelatedAlbums albums={related} />
  </div>
</BaseLayout>
