---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTAButton from '../components/CTAButton.astro';
import EventCard from '../components/EventCard.astro';
import { buildProductMeta, metaMap, CITY_RIVER_TOUR_ID } from '../lib/whatsOn';
import ProductCard from '../components/ProductCard.astro';
import StarRating from '../components/StarRating.astro';
import VentrataWidget from '../components/VentrataWidget.astro';
import DateFinder from '../components/DateFinder.astro';
import SocialBand from '../components/SocialBand.astro';
import { site } from '../data/site';

// ─────────────────────────────────────────────────────────────────────────────
// FEATURED HERO PRODUCT — manual config, NEVER API-selected (AGENTS.md rule 5).
// Defaults to City River Tour. Change here for a seasonal campaign; do not wire
// this to the OCTO API. `title`/`subtitle` drive the hero copy.
// ─────────────────────────────────────────────────────────────────────────────
const heroProduct = {
  title: 'See Manchester from the Water',
  subtitle: 'Sightseeing cruises, live music nights and matchday ferries from Salford Quays',
  href: '/city-river-tour',
  ctaLabel: 'Book the City River Tour',
  image: '/images/hero-city-river-tour.jpg', // placeholder — real WebP asset TBC
  imageAlt: 'The City River Tour boat cruising past MediaCity at Salford Quays',
};

// Google review figures — sourced from src/data/site.ts (single source of truth).
const RATING = site.rating.value;
const REVIEW_COUNT = site.rating.count;

// ─── WHAT'S ON STRIP — LIVE OCTO event-day feed ───────────────────────────────
// Soonest 4 event-days (excluding City River Tour — it has its own section) come from
// /.netlify/functions/event-days, hydrated client-side. The server-rendered core below is a
// crawlable fallback of the soonest event products (no fabricated dates); on feed failure it
// stays — never stale mock data. See src/lib/whatsOn.ts.
const woEvents = await getCollection('events', ({ data }) => !data.draft);
const woProducts = buildProductMeta(woEvents);
const STRIP_META = metaMap(woProducts);
const stripFallback = woProducts.filter((p) => p.productId !== CITY_RIVER_TOUR_ID).slice(0, 4);

// Client hydration for the strip — soonest 4 non-CRT event-days. set:html (Astro emits
// `{`…`}` script bodies literally). META injected below.
const STRIP_SCRIPT = `
(function () {
  var META = ${JSON.stringify(STRIP_META)};
  var CRT = '${CITY_RIVER_TOUR_ID}';
  var grid = document.querySelector('[data-strip-grid]');
  if (!grid) return;
  var fmt = new Intl.DateTimeFormat('en-GB', { weekday: 'short', day: 'numeric', month: 'short' });
  fetch('/.netlify/functions/event-days', { headers: { Accept: 'application/json' } })
    .then(function (r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
    .then(function (data) {
      var days = (data && Array.isArray(data.eventDays) ? data.eventDays : [])
        .filter(function (d) { return d.productId !== CRT && META[d.productId] && d.date; })
        .slice(0, 4);
      if (!days.length) return; // keep crawlable fallback
      grid.textContent = '';
      days.forEach(function (d) { grid.appendChild(buildCard(META[d.productId], d)); });
    })
    .catch(function () { /* keep server-rendered fallback */ });

  function buildCard(m, d) {
    var soldout = d.state === 'sold-out', limited = d.state === 'limited';
    var art = document.createElement('article');
    art.className = 'event-card group flex flex-col overflow-hidden rounded-card bg-white shadow-sm ring-1 ring-black/5 transition hover:-translate-y-0.5 hover:shadow-md hover:ring-black/10';
    var a = document.createElement('a');
    a.href = m.href;
    a.className = 'flex flex-1 flex-col focus-visible:outline focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-primary';
    a.setAttribute('aria-label', m.title + ' \\u2014 ' + (soldout ? 'join waitlist' : 'view & book'));
    var media = document.createElement('div'); media.className = 'relative';
    if (m.image) {
      var img = document.createElement('img');
      img.src = m.image; img.alt = m.imageAlt || m.title; img.width = 800; img.height = 450; img.loading = 'lazy';
      img.setAttribute('data-img-fallback', '');
      img.className = 'aspect-[16/9] w-full object-cover';
      media.appendChild(img);
    } else {
      var ph = document.createElement('div');
      ph.className = 'flex aspect-[16/9] items-center justify-center bg-panel text-xs text-subtle';
      ph.textContent = 'Image (TBC)'; media.appendChild(ph);
    }
    if (soldout || limited) {
      var b = document.createElement('span');
      b.className = 'absolute right-3 top-3 rounded-full px-2.5 py-0.5 text-xs font-semibold ' + (soldout ? 'bg-red-600 text-white' : 'bg-amber-400 text-amber-950');
      b.textContent = soldout ? 'Sold out' : 'Limited availability';
      media.appendChild(b);
    }
    a.appendChild(media);
    var body = document.createElement('div'); body.className = 'flex flex-1 flex-col p-4';
    var date = document.createElement('p'); date.className = 'text-xs font-semibold uppercase tracking-wider text-subtle';
    date.textContent = fmt.format(new Date(d.date + 'T12:00:00'));
    var h = document.createElement('h3'); h.className = 'mt-1 font-semibold text-ink'; h.textContent = m.title;
    var desc = document.createElement('p'); desc.className = 'mt-1 flex-1 text-sm leading-relaxed text-subtle'; desc.textContent = m.description;
    var row = document.createElement('div'); row.className = 'mt-3 flex items-center justify-between';
    if (d.priceFrom != null) {
      var price = document.createElement('span'); price.className = 'text-sm font-bold text-ink';
      price.textContent = 'From \\u00a3' + (Number.isInteger(d.priceFrom) ? d.priceFrom : d.priceFrom.toFixed(2));
      row.appendChild(price);
    } else { row.appendChild(document.createElement('span')); }
    var cta = document.createElement('span'); cta.className = 'text-sm font-medium text-primary group-hover:underline';
    cta.textContent = soldout ? 'Join waitlist' : 'View & book';
    row.appendChild(cta);
    body.appendChild(date); body.appendChild(h); body.appendChild(desc); body.appendChild(row);
    a.appendChild(body); art.appendChild(a);
    return art;
  }
})();
`;

// ─────────────────────────────────────────────────────────────────────────────
// DISCOVER TEASERS — 3 newest guides, live from the collection.
// ─────────────────────────────────────────────────────────────────────────────
const discoverTeasers = (await getCollection('discover', ({ data }) => !data.draft))
  .sort((a, b) => (b.data.publishDate?.getTime() ?? 0) - (a.data.publishDate?.getTime() ?? 0))
  .slice(0, 3);

// City River Tour feature — compact fact row.
const factIcons = {
  clock: '<path d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />',
  tag: '<path d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z" /><path d="M6 6h.008v.008H6V6Z" />',
  check: '<path d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />',
};
const cityFacts = [
  { text: '60 minutes', icon: factIcons.clock },
  { text: 'From £13', icon: factIcons.tag },
  { text: 'Free cancellation', icon: factIcons.check },
];

const statTiles = [
  { stat: '43', label: 'Points of interest' },
  { stat: '5', label: 'Vessels in the fleet' },
  { stat: 'Salford Quays', label: 'Departing from' },
];

const SITE = site.url;
const pageTitle = 'Manchester River Cruises | Boat Tours, Events & Ferry from Salford Quays';
const pageDescription =
  'Sightseeing river cruises, live music and party nights, and matchday ferries on the Manchester Ship Canal from Salford Quays. Book direct with Manchester River Cruises.';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      name: site.name,
      url: SITE,
    },
    {
      '@type': ['TouristAttraction', 'LocalBusiness'],
      name: site.name,
      description: pageDescription,
      url: SITE,
      email: site.email,
      address: { '@type': 'PostalAddress', ...site.address },
      geo: { '@type': 'GeoCoordinates', ...site.geo },
      aggregateRating: { '@type': 'AggregateRating', ratingValue: RATING, reviewCount: REVIEW_COUNT, bestRating: 5 },
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription}>
  {/* Ventrata checkout loader now ships site-wide via <Header> (AGENTS rule 9). */}

  {/* Schema.org structured data (WebSite + TouristAttraction/LocalBusiness w/ aggregateRating) */}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

  {/* 1. HERO ─────────────────────────────────────────────────────────────── */}
  <section class="bg-dark text-white">
    <div class="mx-auto grid max-w-6xl gap-10 px-4 py-20 sm:px-6 md:py-28 lg:grid-cols-2 lg:items-center lg:gap-12 lg:px-8">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-accent">Manchester River Cruises</p>
        <h1 class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl md:text-6xl">{heroProduct.title}</h1>
        <p class="mt-5 max-w-xl text-lg leading-relaxed text-white/80">{heroProduct.subtitle}</p>
        <div class="mt-8 flex flex-wrap items-center gap-4">
          <CTAButton href={heroProduct.href}>{heroProduct.ctaLabel}</CTAButton>
          <CTAButton href="/whats-on" variant="outline">What's On</CTAButton>
        </div>
        {/* Trust line */}
        <div class="mt-6 flex items-center gap-2 text-sm text-white/80">
          <StarRating rating={RATING} size="h-4 w-4" />
          <span><span class="font-semibold text-white">{RATING} stars</span> · {REVIEW_COUNT} Google reviews</span>
        </div>
      </div>
      {/* Hero image placeholder — swap for a real WebP asset */}
      <div class="flex aspect-[4/3] items-center justify-center rounded-card bg-white/5 text-xs text-white/40 ring-1 ring-white/10 lg:aspect-[5/4]">
        {heroProduct.imageAlt}
      </div>
    </div>
  </section>

  {/* 2. CITY RIVER TOUR FEATURE (always present regardless of hero config) ─── */}
  <section aria-labelledby="crt" class="mx-auto max-w-6xl px-4 py-16 sm:px-6 md:py-20 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-2 lg:items-center lg:gap-12">
      <div class="flex aspect-[16/10] items-center justify-center rounded-card bg-panel text-xs text-subtle">
        City River Tour photo (TBC)
      </div>
      <div>
        <SectionHeading id="crt">The City River Tour</SectionHeading>
        <p class="mt-6 text-lg leading-relaxed text-body">
          Our signature sightseeing cruise glides along the historic Manchester Ship Canal from Salford
          Quays, with live commentary bringing the waterfront's landmarks and stories to life.
        </p>
        <ul class="mt-6 flex flex-col gap-3 text-sm sm:flex-row sm:flex-wrap sm:items-center sm:gap-6">
          {
            cityFacts.map((f) => (
              <li class="flex items-center gap-2">
                <svg class="h-5 w-5 flex-none text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={f.icon} />
                <span class="text-body">{f.text}</span>
              </li>
            ))
          }
        </ul>
        <div class="mt-8">
          <CTAButton href="/city-river-tour">Book the City River Tour</CTAButton>
        </div>
      </div>
    </div>
  </section>

  {/* 2b. FIND YOUR DATE — calendar-first booking entry ─────────────────────── */}
  <section aria-labelledby="find-date" class="mx-auto max-w-6xl px-4 py-12 sm:px-6 md:py-16 lg:px-8">
    <div class="rounded-card bg-dark px-6 py-10 text-center text-white sm:px-10">
      <h2 id="find-date" class="text-2xl font-bold tracking-tight sm:text-3xl">Find your date</h2>
      <p class="mx-auto mt-3 max-w-xl text-lg leading-relaxed text-white/80">
        Tell us when you're free — see everything sailing that day.
      </p>
      {/* Desktop gets the OCTO-powered date finder (month calendar + selected day's live
          departures/pricing). Mobile keeps the gold pop-up trigger — a full calendar +
          departures panel would dominate a phone homepage. Both rely on the VentrataWidget
          loader already on this page (checkout script + observer) for the pop-up. */}

      {/* Mobile (< md): pop-up trigger (calendar-first Ventrata checkout).
          ⚠ calendarFirst data-config key still pending Ventrata account-manager confirmation. */}
      <div class="mt-8 flex justify-center md:hidden">
        <VentrataWidget
          mode="popup"
          productID="ef45d8bd-529c-4dae-9c35-cd1b8e4e0a75"
          calendarFirst
          label="Find your date"
        />
      </div>

      {/* Desktop (md+): OCTO-powered date finder — calendar left, departures right. */}
      <div class="mt-8 hidden text-left md:block">
        <DateFinder />
      </div>
    </div>
  </section>

  {/* 3. WHAT'S ON STRIP ───────────────────────────────────────────────────── */}
  <section aria-labelledby="coming-up" class="bg-panel">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 md:py-20 lg:px-8">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <SectionHeading id="coming-up">Coming up</SectionHeading>
        <a href="/whats-on" class="text-sm font-medium text-primary hover:underline">See all dates →</a>
      </div>
      {/* Server-rendered crawlable core: soonest event products (no fabricated dates) — the
          no-JS / feed-failure fallback. Hydrated with the soonest 4 live event-days. */}
      <div data-strip-grid class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          stripFallback.map((p) => (
            <EventCard
              type={p.typeLabel}
              title={p.title}
              description={p.description}
              dateLabel="See upcoming dates"
              href={p.href}
              image={p.image}
              imageAlt={p.imageAlt}
            />
          ))
        }
      </div>
      <div class="mt-8">
        <CTAButton href="/whats-on" variant="outline">See all dates</CTAButton>
      </div>
      <script is:inline set:html={STRIP_SCRIPT} />


    </div>
  </section>

  {/* 4. EVENTS GRID ───────────────────────────────────────────────────────── */}
  <section aria-labelledby="nights" class="mx-auto max-w-6xl px-4 py-16 sm:px-6 md:py-20 lg:px-8">
    <SectionHeading id="nights">Nights to remember</SectionHeading>
    <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <ProductCard name="Music Cruises" desc="Live tribute and themed nights — ABBA, Elvis, Dolly, Adele, Soul and more." href="/music-cruises-manchester" linkText="Music cruises" />
      <ProductCard name="Party Nights" desc="Boat parties on the Ship Canal — dancing, drinks and the city skyline." href="/party-boat-manchester" linkText="Party nights" />
      <ProductCard name="Christmas Cruises" desc="Festive party nights and seasonal cruises through the winter." href="/christmas-cruises-manchester" linkText="Christmas cruises" />
    </div>
  </section>

  {/* 5. MUFC FERRY CALLOUT ────────────────────────────────────────────────── */}
  <section aria-labelledby="mufc" class="bg-dark text-white">
    <div class="mx-auto flex max-w-6xl flex-col gap-6 px-4 py-14 sm:px-6 md:flex-row md:items-center md:justify-between lg:px-8">
      <div>
        <h2 id="mufc" class="text-2xl font-bold tracking-tight sm:text-3xl">Matchday by boat</h2>
        <p class="mt-2 max-w-2xl text-lg leading-relaxed text-white/80">
          Skip the matchday traffic and arrive at Old Trafford by ferry along the Ship Canal.
        </p>
      </div>
      <div class="shrink-0">
        <CTAButton href="/boat-to-old-trafford">Boat to Old Trafford</CTAButton>
      </div>
    </div>
  </section>

  {/* 6. PRIVATE HIRE CALLOUT ──────────────────────────────────────────────── */}
  <section aria-labelledby="private" class="mx-auto max-w-6xl px-4 py-16 sm:px-6 md:py-20 lg:px-8">
    <div class="rounded-card bg-panel p-8 ring-1 ring-black/5 sm:flex sm:items-center sm:justify-between sm:gap-6 sm:p-10">
      <div>
        <h2 id="private" class="text-2xl font-bold tracking-tight text-ink sm:text-3xl">Make it yours</h2>
        <p class="mt-2 max-w-2xl text-lg leading-relaxed text-body">
          Charter a boat exclusively for your celebration, corporate event or private party.
        </p>
      </div>
      <div class="mt-6 shrink-0 sm:mt-0">
        <CTAButton href="/private-hire" variant="outline">Private hire</CTAButton>
      </div>
    </div>
  </section>

  {/* 7. DISCOVER TEASERS ──────────────────────────────────────────────────── */}
  <section aria-labelledby="discover" class="bg-panel">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 md:py-20 lg:px-8">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <SectionHeading id="discover">Plan your day</SectionHeading>
        <a href="/discover" class="text-sm font-medium text-primary hover:underline">All guides →</a>
      </div>
      <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          discoverTeasers.map((g) => (
            <ProductCard
              name={g.data.title}
              desc={g.data.description}
              href={`/discover/${g.id}`}
              linkText="Read guide"
              imageLabel={g.data.heroImageAlt ?? 'Image (TBC)'}
            />
          ))
        }
      </div>
    </div>
  </section>

  {/* 8. SOCIAL PROOF ──────────────────────────────────────────────────────── */}
  <section aria-labelledby="proof" class="mx-auto max-w-6xl px-4 py-16 sm:px-6 md:py-20 lg:px-8">
    <h2 id="proof" class="sr-only">Why book with us</h2>
    <div class="flex flex-col items-center gap-3 text-center">
      <StarRating rating={RATING} size="h-7 w-7" />
      <p class="text-2xl font-bold text-ink">
        {RATING} / 5
        <span class="ml-2 align-middle text-base font-normal text-subtle">from {REVIEW_COUNT} Google reviews</span>
      </p>
    </div>
    <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-3">
      {
        statTiles.map((t) => (
          <div class="rounded-card bg-panel p-8 text-center ring-1 ring-black/5">
            <div class="text-3xl font-bold text-primary sm:text-4xl">{t.stat}</div>
            <div class="mt-2 text-sm text-subtle">{t.label}</div>
          </div>
        ))
      }
    </div>
  </section>

  {/* SOCIAL BAND — slim strip directly above the footer */}
  <SocialBand />
</BaseLayout>
