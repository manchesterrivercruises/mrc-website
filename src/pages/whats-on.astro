---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import EventCard from '../components/EventCard.astro';
import { getCollection } from 'astro:content';
import { site } from '../data/site';
import { buildProductMeta, metaMap } from '../lib/whatsOn';

// What's On is driven by the LIVE OCTO event-day feed (/.netlify/functions/event-days):
// one card per PRODUCT×DATE (e.g. ABBA on the 12th and 19th = two cards). The page
// server-renders a CRAWLABLE CORE — one honest product-link card per product, no dates —
// which is also the no-JS / feed-failure fallback (never stale mock data). A client script
// then replaces that grid with real dated event-day cards (from-price + availability badge)
// and re-runs the existing type/date filters. See docs/ventrata-integration.md.

const events = await getCollection('events', ({ data }) => !data.draft);
const products = buildProductMeta(events);
const META = metaMap(products);

const typeFilters = [
  { value: 'all', label: 'All' },
  { value: 'events', label: 'Events', isDefault: true },
  { value: 'mufc', label: 'MUFC Ferry' },
  { value: 'crt', label: 'City River Tour' },
];
const dateFilters = [
  { value: 'week', label: 'This week', isDefault: true },
  { value: 'month', label: 'This month' },
  { value: '3months', label: 'Next 3 months' },
  { value: '6months', label: 'Next 6 months' },
  { value: 'all', label: 'All dates' },
];

const venues = [
  { name: 'Kargo', tagline: 'Waterfront bar and kitchen', distance: '3 min walk' },
  { name: 'The Alchemist', tagline: 'Cocktail bar and restaurant', distance: '5 min walk' },
  { name: "Nell's Pizza", tagline: 'Sourdough pizza', distance: '8 min walk' },
  { name: 'Holiday Inn MediaCity', tagline: 'Hotel', distance: '5 min walk' },
];

const SITE = site.url;
const pageTitle = "What's On — Manchester River Cruises";
const pageDescription =
  'Upcoming departures and events on the Manchester Ship Canal — City River Tour sightseeing cruises, live music and party nights, and Boat to Old Trafford matchday ferries. Book direct.';

const pillClass =
  'inline-block rounded-full border border-black/15 px-4 py-1.5 text-sm font-medium text-body transition hover:border-primary/50 peer-checked:border-primary peer-checked:bg-primary peer-checked:text-white peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-primary peer-disabled:opacity-40 peer-disabled:cursor-not-allowed';
const dateInputClass =
  'rounded-md border border-black/15 bg-white px-3 py-1.5 text-sm text-ink focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary';

// HONEST structured data — an ItemList of the real product pages (name + url + image). No
// fabricated event dates / prices / InStock (that would require the live feed at build time;
// per-event-day Event schema is a Simon decision to enable a build-time OCTO fetch). This
// replaces the previously-withheld mock schema.
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: pageTitle,
  itemListElement: products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: p.title,
    url: `${SITE}${p.href}`,
  })),
};

// Client hydration: fetch the live event-day feed and rebuild the grid, one card per
// event-day. set:html (Astro emits `{`…`}` script bodies literally). META injected below.
const HYDRATE_SCRIPT = `
(function () {
  var META = ${JSON.stringify(META)};
  var grid = document.querySelector('[data-event-grid]');
  if (!grid) return;
  var fmt = new Intl.DateTimeFormat('en-GB', { weekday: 'short', day: 'numeric', month: 'short' });

  fetch('/.netlify/functions/event-days', { headers: { Accept: 'application/json' } })
    .then(function (r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
    .then(function (data) {
      var days = data && Array.isArray(data.eventDays) ? data.eventDays : [];
      var cards = [];
      days.forEach(function (d) {
        var m = META[d.productId];
        if (!m || !d.date) return; // no product page → skip
        cards.push(buildCard(m, d));
      });
      if (!cards.length) return; // keep the crawlable product-link fallback
      grid.textContent = '';
      cards.forEach(function (c) { grid.appendChild(c); });
      if (typeof window.__applyWhatsOnFilters === 'function') window.__applyWhatsOnFilters();
    })
    .catch(function (err) {
      if (window.console && console.debug) console.debug('What\\u2019s On: live feed unavailable —', err);
      // keep the server-rendered product-link cards (the crawlable fallback)
    });

  function badge(state) {
    if (state === 'sold-out') return { cls: 'bg-red-600 text-white', text: 'Sold out', av: 'soldout', cta: 'Join waitlist' };
    if (state === 'limited') return { cls: 'bg-amber-400 text-amber-950', text: 'Limited availability', av: 'limited', cta: 'View & book' };
    return { cls: '', text: '', av: 'available', cta: 'View & book' };
  }

  function buildCard(m, d) {
    var b = badge(d.state);
    var item = document.createElement('div');
    item.className = 'event-item contents';
    item.setAttribute('data-type', m.type);
    item.setAttribute('data-date', d.date);

    var art = document.createElement('article');
    art.className = 'event-card group flex flex-col overflow-hidden rounded-card bg-white shadow-sm ring-1 ring-black/5 transition hover:-translate-y-0.5 hover:shadow-md hover:ring-black/10';
    art.setAttribute('data-type', m.typeLabel);
    art.setAttribute('data-availability', b.av);

    var a = document.createElement('a');
    a.href = m.href;
    a.className = 'flex flex-1 flex-col focus-visible:outline focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-primary';
    a.setAttribute('aria-label', m.title + ' \\u2014 ' + (b.av === 'soldout' ? 'join waitlist' : 'view & book'));

    var media = document.createElement('div');
    media.className = 'relative';
    if (m.image) {
      var img = document.createElement('img');
      img.src = m.image; img.alt = m.imageAlt || m.title; img.width = 800; img.height = 450; img.loading = 'lazy';
      img.className = 'aspect-[16/9] w-full object-cover';
      media.appendChild(img);
    } else {
      var ph = document.createElement('div');
      ph.className = 'flex aspect-[16/9] items-center justify-center bg-panel text-xs text-subtle';
      ph.textContent = 'Image (TBC)';
      media.appendChild(ph);
    }
    if (b.text) {
      var badgeEl = document.createElement('span');
      badgeEl.className = 'absolute right-3 top-3 rounded-full px-2.5 py-0.5 text-xs font-semibold ' + b.cls;
      badgeEl.textContent = b.text;
      media.appendChild(badgeEl);
    }
    a.appendChild(media);

    var body = document.createElement('div');
    body.className = 'flex flex-1 flex-col p-4';
    var date = document.createElement('p');
    date.className = 'text-xs font-semibold uppercase tracking-wider text-subtle';
    date.textContent = fmt.format(new Date(d.date + 'T12:00:00'));
    var h = document.createElement('h3');
    h.className = 'mt-1 font-semibold text-ink';
    h.textContent = m.title;
    var desc = document.createElement('p');
    desc.className = 'mt-1 flex-1 text-sm leading-relaxed text-subtle';
    desc.textContent = m.description;
    var row = document.createElement('div');
    row.className = 'mt-3 flex items-center justify-between';
    if (d.priceFrom != null) {
      var price = document.createElement('span');
      price.className = 'text-sm font-bold text-ink';
      price.textContent = 'From \\u00a3' + (Number.isInteger(d.priceFrom) ? d.priceFrom : d.priceFrom.toFixed(2));
      row.appendChild(price);
    } else {
      row.appendChild(document.createElement('span'));
    }
    var cta = document.createElement('span');
    cta.className = 'text-sm font-medium text-primary group-hover:underline';
    cta.textContent = b.cta;
    row.appendChild(cta);

    body.appendChild(date); body.appendChild(h); body.appendChild(desc); body.appendChild(row);
    a.appendChild(body);
    art.appendChild(a);
    item.appendChild(art);
    return item;
  }
})();
`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  {/* Honest ItemList of the real product pages (no fabricated dates/prices). */}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 md:py-16 lg:px-8">
    <h1 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl md:text-5xl">What's On</h1>
    <p class="mt-4 max-w-2xl text-lg leading-relaxed text-body">
      Upcoming departures and events on the Manchester Ship Canal — sightseeing cruises, live music
      and party nights, and matchday ferries to Old Trafford.
    </p>

    <div class="whats-on mt-8">
      {/* Tour-type filter */}
      <fieldset class="m-0 flex flex-wrap gap-2 border-0 p-0">
        <legend class="sr-only">Filter by tour type</legend>
        {
          typeFilters.map((f) => (
            <label class="cursor-pointer">
              <input type="radio" name="wo-type" value={f.value} checked={f.isDefault} class="peer sr-only" />
              <span class={pillClass}>{f.label}</span>
            </label>
          ))
        }
      </fieldset>

      {/* Date quick-filters */}
      <fieldset id="wo-date-filters" class="m-0 mt-3 flex flex-wrap gap-2 border-0 p-0 transition-opacity">
        <legend class="sr-only">Filter by date</legend>
        {
          dateFilters.map((f) => (
            <label class="cursor-pointer">
              <input type="radio" name="wo-date" value={f.value} checked={f.isDefault} class="peer sr-only" />
              <span class={pillClass}>{f.label}</span>
            </label>
          ))
        }
      </fieldset>

      {/* Date range picker — when BOTH dates are set it overrides the quick-filters above. */}
      <div class="mt-3 flex flex-wrap items-center gap-2 text-sm">
        <label for="wo-from" class="font-medium text-body">From</label>
        <input type="date" id="wo-from" class={dateInputClass} aria-label="From date" />
        <label for="wo-to" class="font-medium text-body">To</label>
        <input type="date" id="wo-to" class={dateInputClass} aria-label="To date" />
        <button type="button" id="wo-clear-dates" class="ml-1 font-medium text-primary hover:underline">
          Clear dates
        </button>
      </div>

      {/* Grid. SERVER-RENDERED CRAWLABLE CORE: one product-link card per product (no dates) —
          also the no-JS / feed-failure fallback. The hydration script replaces these with
          real dated event-day cards. Undated cards carry an empty data-date (never hidden by
          the date filter). */}
      <div data-event-grid class="event-grid mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          products.map((p) => (
            <div class="event-item contents" data-type={p.type} data-date="">
              <EventCard
                type={p.typeLabel}
                title={p.title}
                description={p.description}
                dateLabel="See upcoming dates"
                href={p.href}
                image={p.image}
                imageAlt={p.imageAlt}
              />
            </div>
          ))
        }
      </div>

      <p class="wo-empty mt-6 text-subtle" hidden>
        No events match these filters — try a different tour type or date range.
      </p>
    </div>
  </section>

  {/* "Before or after your cruise" venues strip — TEMPORARY, lightweight. */}
  <section class="mx-auto max-w-6xl px-4 pb-12 sm:px-6 md:pb-16 lg:px-8">
    <SectionHeading as="h2">Before or after your cruise</SectionHeading>
    <p class="mt-4 max-w-2xl text-body">A few favourites within a short walk of the boarding point.</p>
    <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4 sm:gap-4">
      {
        venues.map((v) => (
          <div class="overflow-hidden rounded-card bg-white shadow-sm ring-1 ring-black/5">
            <div class="flex aspect-[16/10] items-center justify-center bg-panel text-xs text-subtle">Image (TBC)</div>
            <div class="p-3">
              <h3 class="text-sm font-semibold text-ink">{v.name}</h3>
              <p class="mt-0.5 text-xs leading-relaxed text-subtle">{v.tagline}</p>
              <p class="mt-1 text-xs font-medium text-primary">{v.distance}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  {/* Live event-day hydration (set:html — injects the evaluated IIFE + embedded META). */}
  <script is:inline set:html={HYDRATE_SCRIPT} />

  {/* Client filter: combine tour-type + date, show/hide cards. Undated fallback cards
      (empty data-date) are never hidden by the date filter. Exposed globally so the
      hydration script can re-apply after it swaps in the live cards. */}
  <script>
    function applyWhatsOnFilters() {
      const typeEl = document.querySelector('input[name="wo-type"]:checked') as HTMLInputElement | null;
      const dateEl = document.querySelector('input[name="wo-date"]:checked') as HTMLInputElement | null;
      const fromEl = document.getElementById('wo-from') as HTMLInputElement | null;
      const toEl = document.getElementById('wo-to') as HTMLInputElement | null;
      if (!typeEl) return;

      const type = typeEl.value;
      const dateFilter = dateEl ? dateEl.value : 'all';
      const fromMs = fromEl && fromEl.value ? new Date(fromEl.value + 'T00:00:00').getTime() : null;
      const toMs = toEl && toEl.value ? new Date(toEl.value + 'T23:59:59').getTime() : null;
      const rangeActive = fromMs !== null && toMs !== null;
      const now = Date.now();
      let visible = 0;

      document.querySelectorAll<HTMLElement>('.event-item').forEach((item) => {
        const t = item.getAttribute('data-type');
        const raw = item.getAttribute('data-date') || '';
        const ms = raw ? new Date(raw).getTime() : NaN;
        const days = (ms - now) / 86400000;
        const matchType = type === 'all' || t === type;
        let matchDate;
        if (Number.isNaN(ms)) matchDate = true; // undated fallback card — always show
        else if (rangeActive) matchDate = ms >= (fromMs as number) && ms <= (toMs as number);
        else if (dateFilter === 'week') matchDate = days >= -1 && days <= 7;
        else if (dateFilter === 'month') matchDate = days >= -1 && days <= 30;
        else if (dateFilter === '3months') matchDate = days >= -1 && days <= 90;
        else if (dateFilter === '6months') matchDate = days >= -1 && days <= 180;
        else matchDate = true; // 'all'
        const show = matchType && matchDate;
        item.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      document.querySelectorAll<HTMLInputElement>('input[name="wo-date"]').forEach((el) => {
        el.disabled = rangeActive;
      });

      const empty = document.querySelector('.wo-empty') as HTMLElement | null;
      if (empty) empty.hidden = visible > 0;
    }

    (window as unknown as { __applyWhatsOnFilters?: () => void }).__applyWhatsOnFilters = applyWhatsOnFilters;

    document
      .querySelectorAll('input[name="wo-type"], input[name="wo-date"], #wo-from, #wo-to')
      .forEach((el) => {
        el.addEventListener('change', applyWhatsOnFilters);
        el.addEventListener('input', applyWhatsOnFilters);
      });

    document.getElementById('wo-clear-dates')?.addEventListener('click', () => {
      const fromEl = document.getElementById('wo-from') as HTMLInputElement | null;
      const toEl = document.getElementById('wo-to') as HTMLInputElement | null;
      if (fromEl) fromEl.value = '';
      if (toEl) toEl.value = '';
      applyWhatsOnFilters();
    });

    applyWhatsOnFilters();
  </script>
</BaseLayout>
