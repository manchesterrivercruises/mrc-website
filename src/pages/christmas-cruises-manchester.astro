---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
import SectionHeading from '../components/SectionHeading.astro';
import FAQSection from '../components/FAQSection.astro';
import CTAButton from '../components/CTAButton.astro';
import GettingHere from '../components/GettingHere.astro';
import KeyFacts from '../components/KeyFacts.astro';
import EventGalleryStrip from '../components/EventGalleryStrip.astro';
import { getAlbums } from '../lib/gallery';

// Christmas HUB — routes three festive audiences, honestly. Confirmed reality: there are NO
// Christmas-specific PUBLIC events except the Santa cruise. The regular party nights simply run
// through December with the full Christmas treatment (boat decorated, festive extras, Christmas
// songs mixed in). So this page does NOT embed a product/booking widget and claims no Event/Product
// schema — it points to /whats-on (party nights), /private-hire (your own do) and the Santa page.
const albums = await getAlbums();
const christmasAlbum = albums.find((a) => a.data.slug === 'christmas-cruises' || a.id === 'christmas-cruises');

const icons = {
  calendar:
    '<path d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />',
  gift: '<path d="M21 11.25v8.25a1.5 1.5 0 0 1-1.5 1.5H5.25a1.5 1.5 0 0 1-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 1 0 9.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1 1 14.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" />',
  pin: '<path d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />',
  sparkles:
    '<path d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" /><path d="M18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z" />',
};

const keyFacts = [
  { text: 'Party nights, private hire & Santa cruises', icon: icons.sparkles },
  { text: 'Fully decorated all through December', icon: icons.calendar },
  { text: 'Millennium Footbridge, Salford Quays', icon: icons.pin },
  { text: 'Book early — December sells out', icon: icons.gift },
];

// The three festive journeys. `featured` marks the highest-value strand (private hire).
const journeys = [
  {
    id: 'party-nights',
    eyebrow: 'Party nights',
    title: 'Party nights, dressed for Christmas',
    copy: 'All our regular party nights — ABBA, Dolly, Elvis, Soul and more — get the full Christmas treatment through December: the boat decorated bow to stern, festive extras on board and Christmas songs in the mix. Same great nights, in full festive dress.',
    image: '/images/gallery/abba-night/01.webp',
    imageAlt: 'A tribute act performing under coloured stage lights on a party cruise',
    cta: { label: 'See December party nights', href: '/whats-on?month=2026-12' },
    featured: false,
  },
  {
    id: 'private-party',
    eyebrow: 'Private hire',
    title: 'Your own Christmas party',
    copy: 'The whole boat, exclusively yours — the standout way to do the office Christmas do or a big group celebration. Your own decorated boat, your own night on the water, with a licensed bar and the floodlit waterfront gliding past. December dates go fast, so get yours locked in.',
    image: '/images/gallery/private-hire/boat-dressed-for-valentines.webp',
    imageAlt: 'The boat cabin dressed for a private celebration with decorations and laid tables',
    cta: { label: 'Plan a private Christmas party', href: '/private-hire' },
    featured: true,
  },
  {
    id: 'santa',
    eyebrow: 'Family',
    title: 'Santa cruises',
    copy: 'The one truly Christmas-specific event: a magical family cruise where little ones meet Father Christmas himself on the water, with a festively decorated cabin and a gift for every child. Pure festive magic for the countdown to Christmas.',
    image: '/images/gallery/christmas-cruises/child-at-the-wheel-with-santa-card.webp',
    imageAlt: 'A child at the wheel of the boat alongside Father Christmas',
    cta: { label: 'Meet Father Christmas', href: '/santa-cruise-manchester' },
    featured: false,
  },
];

const faqs = [
  {
    q: 'Do you run special Christmas events?',
    a: 'Our regular party nights run right through December with the full Christmas treatment — the boat decorated bow to stern, festive extras on board and Christmas songs mixed into the night. The one Christmas-specific event is our family Santa cruise. For a do of your own, hire the whole boat.',
  },
  {
    q: 'Can I book a private Christmas party?',
    a: 'Yes — hire the whole boat for your office party or group celebration, with the boat decorated for Christmas. Catering, drinks packages and festive extras — TBC from Simon. Enquire via our private hire page; December books up early.',
  },
  {
    q: 'When should I book for December?',
    a: 'December is our busiest month and party nights and private dates sell out, so book as early as you can. Exact deadlines — TBC.',
  },
  {
    q: 'What should I wear?',
    a: 'Dress warmly (and festively!). There is a heated indoor cabin, but the open deck can be cold in winter. (TBC)',
  },
  {
    q: 'Are the Christmas cruises accessible?',
    a: 'Step-free boarding is available where tides allow, and our sensory-friendly SEN Santa cruise is designed for children with additional needs. Full accessibility details — TBC.',
  },
];

const SITE = site.url;
// Meta targets the hub intent — "Christmas cruises Manchester" + "Christmas party boat Manchester".
// The Santa page keeps "Santa cruise" ownership, so there is no title cannibalisation.
const pageTitle = 'Christmas Cruises & Christmas Party Boat Manchester — Manchester River Cruises';
const pageDescription =
  'Christmas on the Manchester Ship Canal from Salford Quays: party nights that run through December fully decorated with festive extras, private Christmas parties for your office or group, and family Santa cruises. Book direct.';

// Schema.org — TouristAttraction + FAQPage ONLY. No Product/Offer/InStock: this hub sells no single
// dated product (party dates live in Ventrata; the Santa product lives on its own page), so a Product
// with a price/InStock offer here would be dishonest — and was deliberately removed in this pass.
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'TouristAttraction',
      name: 'Christmas Cruises Manchester',
      description: pageDescription,
      url: `${SITE}/christmas-cruises-manchester`,
      touristType: 'Christmas',
      availableLanguage: 'English',
      address: { '@type': 'PostalAddress', ...site.address },
      geo: { '@type': 'GeoCoordinates', ...site.geo },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription}>
  {/* Schema.org (TouristAttraction + FAQPage — no Product/Offer/InStock; the hub sells no single product) */}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

  <div>
    {/* Hero — dark navy, gold accents, festive feel */}
    <section class="bg-dark text-white">
      <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 md:py-28 lg:px-8">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-accent">Christmas on the water</p>
        <h1 class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl md:text-6xl">
          Christmas Cruises Manchester
        </h1>
        <p class="mt-5 max-w-2xl text-lg leading-relaxed text-white/80">
          Three ways to celebrate on the Manchester Ship Canal this December — a decked-out party
          night, your own private do, or a Santa cruise for the family.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-4">
          <CTAButton href="#strands">See your options</CTAButton>
          <span class="text-sm text-white/70">Fully decorated all through December</span>
        </div>
      </div>
    </section>

    {/* Key facts strip */}
    <KeyFacts facts={keyFacts} />

    {/* THREE JOURNEY CARDS — the router, high on the page */}
    <section id="strands" aria-labelledby="strands-heading" class="mx-auto max-w-6xl px-4 py-12 sm:px-6 md:py-16 lg:px-8">
      <SectionHeading id="strands-heading">Choose your Christmas</SectionHeading>
      <div class="mt-8 grid grid-cols-1 gap-5 md:grid-cols-3">
        {
          journeys.map((j) => (
            <article
              class={`flex flex-col overflow-hidden rounded-card bg-white shadow-sm ring-1 ${j.featured ? 'ring-2 ring-primary/50' : 'ring-black/5'}`}
            >
              <div class="relative">
                <img
                  src={j.image}
                  alt={j.imageAlt}
                  width="800"
                  height="450"
                  loading="lazy"
                  data-img-fallback
                  class="aspect-[16/9] w-full object-cover"
                />
                {j.featured && (
                  <span class="absolute left-3 top-3 rounded-full bg-primary px-2.5 py-0.5 text-xs font-semibold text-white">
                    Most-booked for groups
                  </span>
                )}
              </div>
              <div class="flex flex-1 flex-col p-6">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary">{j.eyebrow}</p>
                <h3 class="mt-2 text-lg font-bold text-ink">{j.title}</h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-body">{j.copy}</p>
                <div class="mt-5">
                  <CTAButton href={j.cta.href} variant={j.featured ? 'primary' : 'outline'} class="w-full">
                    {j.cta.label}
                  </CTAButton>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    {/* Per-strand detail + gallery + FAQ + gift cross-sell */}
    <div class="mx-auto max-w-6xl px-4 pb-12 sm:px-6 md:pb-16 lg:px-8">
      <div class="space-y-14">
        {/* Strand detail sections */}
        <section aria-labelledby="party-detail">
          <SectionHeading id="party-detail" as="h2">Party nights, dressed for Christmas</SectionHeading>
          <div class="mt-4 max-w-3xl space-y-4 text-body">
            <p>
              We don’t run separate “Christmas specials” — we don’t need to. Every one of our regular
              party nights runs right through December with the full festive treatment: the boat
              decorated bow to stern, festive extras on board, and Christmas songs woven into the set.
              Whether it’s ABBA, Dolly, Elvis or a soul night, you get the same great cruise with all
              the Christmas sparkle on top.
            </p>
            <p>
              <a href="/whats-on?month=2026-12" class="font-medium text-primary underline-offset-4 hover:underline">
                See what’s sailing in December →
              </a>
            </p>
          </div>
        </section>

        <section aria-labelledby="private-detail">
          <SectionHeading id="private-detail" as="h2">Your own Christmas party</SectionHeading>
          <div class="mt-4 max-w-3xl space-y-4 text-body">
            <p>
              The office Christmas do, sorted. Take the whole boat and it’s exclusively yours for the
              night — decorated for Christmas, with a licensed bar, a dancefloor and Manchester’s
              floodlit waterfront as your backdrop. It’s the highest-impact way to celebrate a team or
              a big group, and it beats booking out the same tired function room.
            </p>
            <p class="text-base text-subtle">Catering, drinks packages and festive extras — TBC from Simon (content-checklist.md).</p>
            <p>
              <a href="/private-hire" class="font-medium text-primary underline-offset-4 hover:underline">
                Enquire about a private Christmas party →
              </a>
            </p>
          </div>
        </section>

        <section aria-labelledby="santa-detail">
          <SectionHeading id="santa-detail" as="h2">Santa cruises</SectionHeading>
          <div class="mt-4 max-w-3xl space-y-4 text-body">
            <p>
              Our one truly Christmas-specific event. Little ones meet Father Christmas on the water,
              in a warm, festively decorated cabin, with a gift for every child — plus a
              sensory-friendly SEN Santa cruise for children with additional needs.
            </p>
            <p>
              <a href="/santa-cruise-manchester" class="font-medium text-primary underline-offset-4 hover:underline">
                Meet Father Christmas on the water →
              </a>
            </p>
          </div>
        </section>

        {/* Christmas gallery imagery */}
        {
          christmasAlbum && (
            <EventGalleryStrip
              album={christmasAlbum}
              heading="Christmas on board"
              lead="Real festive moments on the water — tap to browse"
            />
          )
        }

        {/* Getting Here (shared component) */}
        <GettingHere />

        {/* FAQ */}
        <FAQSection faqs={faqs} title="Christmas cruise FAQs" />

        {/* Gift voucher cross-sell */}
        <section aria-labelledby="gift-vouchers">
          <div class="rounded-card bg-panel p-6 ring-1 ring-black/5 sm:flex sm:items-center sm:justify-between sm:gap-6">
            <div>
              <h2 id="gift-vouchers" class="text-lg font-semibold text-ink">Can’t pick a date? Give a voucher</h2>
              <p class="mt-1 text-sm leading-relaxed text-body">
                A gift voucher is the easy Christmas present — they pick the cruise and the date that
                suits them. Redeemable against any sailing.
              </p>
            </div>
            <div class="mt-4 shrink-0 sm:mt-0">
              <CTAButton href="/gift-vouchers" variant="outline">Gift vouchers</CTAButton>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
</BaseLayout>
