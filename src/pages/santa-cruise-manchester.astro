---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import BookingPanel from '../components/BookingPanel.astro';
import ProductCard from '../components/ProductCard.astro';
import FAQSection from '../components/FAQSection.astro';
import CTAButton from '../components/CTAButton.astro';
import GettingHere from '../components/GettingHere.astro';

// Santa Cruise product — booking panel + mobile sticky CTA.
// Ventrata checkout widget/script wired in a later step; placeholder for now.
const SANTA_CRUISE_ID = '6cabf36f-f48f-48c7-83c0-c964983a9dff';

const icons = {
  calendar:
    '<path d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />',
  tag: '<path d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z" /><path d="M6 6h.008v.008H6V6Z" />',
  users:
    '<path d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />',
  gift: '<path d="M21 11.25v8.25a1.5 1.5 0 0 1-1.5 1.5H5.25a1.5 1.5 0 0 1-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 1 0 9.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1 1 14.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" />',
};

const keyFacts = [
  { text: 'December dates', icon: icons.calendar },
  { text: 'From £13 per person', icon: icons.tag },
  { text: 'Families welcome', icon: icons.users },
  { text: 'Father Christmas onboard', icon: icons.gift },
];

const bookDirect = [
  'Official source — you book direct with the operator.',
  'Always the latest live availability.',
  'Direct support from the Manchester River Cruises team.',
];

const faqs = [
  { q: 'Is there an age limit?', a: 'Santa cruises are designed for families with young children, but all ages are welcome. (TBC)' },
  { q: 'What does Santa bring?', a: 'Every child meets Father Christmas and receives a gift onboard. (Details TBC.)' },
  { q: 'Is there a sensory-friendly SEN cruise?', a: 'Yes — we run a relaxed, sensory-friendly SEN Santa cruise for children with additional needs. (TBC)' },
  { q: 'When is the booking deadline?', a: 'Santa cruises sell out quickly — we recommend booking early. Exact deadlines TBC.' },
];

const SITE = 'https://www.manchesterrivercruises.com';
const pageTitle = 'Santa Cruise Manchester — Meet Father Christmas on the Water';
const pageDescription =
  'Santa Cruise Manchester — a magical festive cruise on the Manchester Ship Canal where children meet Father Christmas onboard. Families welcome, from £13. Book direct.';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'TouristAttraction',
      name: 'Santa Cruise Manchester',
      description: pageDescription,
      url: `${SITE}/santa-cruise-manchester`,
      touristType: 'Christmas',
      availableLanguage: 'English',
      address: { '@type': 'PostalAddress', streetAddress: 'Millennium Footbridge, The Quays', addressLocality: 'Salford', postalCode: 'M50 3RB', addressCountry: 'GB' },
      geo: { '@type': 'GeoCoordinates', latitude: 53.4705, longitude: -2.296 },
    },
    {
      '@type': 'Event',
      name: 'Cruise with Father Christmas',
      description: 'A magical festive cruise where children meet Father Christmas on the Manchester Ship Canal.',
      startDate: '2026-12-06T15:00:00',
      eventStatus: 'https://schema.org/EventScheduled',
      eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
      location: { '@type': 'Place', name: 'Millennium Footbridge, Salford Quays', address: { '@type': 'PostalAddress', streetAddress: 'Millennium Footbridge, The Quays', addressLocality: 'Salford', postalCode: 'M50 3RB', addressCountry: 'GB' } },
      url: `${SITE}/santa-cruise-manchester`,
      offers: { '@type': 'Offer', price: 13, priceCurrency: 'GBP', availability: 'https://schema.org/InStock', url: `${SITE}/santa-cruise-manchester` },
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription}>
  {/* Schema.org structured data (TouristAttraction + Event) */}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

  <div class="pb-24 md:pb-0">
    {/* Hero — dark navy, gold accents, magical festive tone */}
    <section class="bg-dark text-white">
      <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 md:py-28 lg:px-8">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-accent">A magical festive cruise</p>
        <h1 class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl md:text-6xl">Santa Cruise Manchester</h1>
        <p class="mt-5 max-w-2xl text-lg leading-relaxed text-white/80">Meet Father Christmas on the water.</p>
        <div class="mt-8 flex flex-wrap items-center gap-4">
          <CTAButton href="#book">Book Now</CTAButton>
          <span class="text-sm text-white/70">From £13 · December</span>
        </div>
      </div>
    </section>

    {/* Key facts strip */}
    <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mt-6 flex flex-col gap-3 border-y border-black/10 py-4 text-sm sm:flex-row sm:flex-wrap sm:items-center">
        {
          keyFacts.map((f, i) => (
            <div class={`flex items-center gap-2 ${i > 0 ? 'sm:border-l sm:border-black/10 sm:pl-6' : ''}`}>
              <svg class="h-4.5 w-4.5 flex-none text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={f.icon} />
              <span class="text-body">{f.text}</span>
            </div>
          ))
        }
      </div>
    </section>

    {/* Two-column: left content + right sticky booking panel */}
    <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 md:py-12 lg:grid lg:grid-cols-[58%_38%] lg:items-start lg:gap-[4%] lg:px-8">
      {/* Right column — booking panel (Santa Cruise 6cabf36f). Widget placeholder only. */}
      <aside id="book" class="mb-10 lg:order-2 lg:mb-0 lg:sticky lg:top-20">
        <BookingPanel price="£13" priceNote="Adults £13 · Children TBC" bookDirect={bookDirect} />
      </aside>

      {/* Left column — main content */}
      <div class="space-y-12 md:space-y-14 lg:order-1">
        <section aria-labelledby="about">
          <SectionHeading id="about">A cruise the whole family will remember</SectionHeading>
          <div class="mt-6 max-w-3xl space-y-4 text-lg leading-relaxed text-body">
            <p>
              Climb aboard for a magical trip along the Manchester Ship Canal, where little ones can
              meet Father Christmas himself. With a warm, festively decorated cabin, seasonal music
              and a special gift for every child, it's the perfect way to add some sparkle to the
              countdown to Christmas.
            </p>
            <p class="text-base text-subtle">Full description and highlights — TBC from Simon (content-checklist.md).</p>
          </div>
        </section>

        <GettingHere />

        <FAQSection faqs={faqs} title="Santa cruise FAQs" />

        {/* Cross-sell to City River Tour */}
        <section aria-labelledby="also">
          <SectionHeading id="also">Also popular</SectionHeading>
          <div class="mt-8 sm:max-w-sm">
            <ProductCard name="City River Tour" desc="Our signature 60-minute sightseeing cruise along the Manchester Ship Canal." href="/city-river-tour" />
          </div>
        </section>
      </div>
    </div>
  </div>

  {/* Mobile sticky Book Now (Santa Cruise) — scrolls to the booking panel; no Ventrata script yet. */}
  <div class="fixed inset-x-0 bottom-0 z-40 border-t border-black/10 bg-white/95 p-3 backdrop-blur md:hidden">
    <CTAButton href="#book" class="w-full">Book Now</CTAButton>
  </div>
</BaseLayout>
