---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTAButton from '../components/CTAButton.astro';
import { site } from '../data/site';

const SITE = site.url;
const pageTitle = 'Contact Us — Manchester River Cruises';
const pageDescription =
  'Contact Manchester River Cruises — get in touch with our team by email, phone or using our enquiry form. Departing from Millennium Footbridge, Salford Quays.';

const subjects = ['General Enquiry', 'Booking Help', 'Group Travel', 'Private Hire', 'Press/Media', 'Other'];
// Real social profiles from site.ts (single source of truth) — same set the footer uses.
const social = [
  { label: 'Facebook', href: site.socials.facebook },
  { label: 'Instagram', href: site.socials.instagram },
  { label: 'TikTok', href: site.socials.tiktok },
  { label: 'Tripadvisor', href: site.socials.tripadvisor },
];

const inputClass =
  'mt-1 w-full rounded-md border border-black/15 bg-white px-3 py-2 text-sm text-ink focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary';
const fieldLabel = 'block text-sm font-medium text-ink';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'ContactPage', name: 'Contact Us', description: pageDescription, url: `${SITE}/contact` },
    {
      '@type': 'LocalBusiness',
      name: site.name,
      url: site.url,
      email: site.email,
      telephone: site.phone,
      address: { '@type': 'PostalAddress', ...site.address },
      geo: { '@type': 'GeoCoordinates', ...site.geo },
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription}>
  {/* Schema.org structured data (ContactPage + LocalBusiness) */}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

  <style is:global>
    /* Success confirmation is revealed by CSS (:target) when the URL carries the
       #contact-success fragment — no JS required for the message itself. */
    #contact-success { display: none; }
    #contact-success:target { display: block; }
    /* Smooth-scroll to it only when the user hasn't asked to reduce motion. */
    @media (prefers-reduced-motion: no-preference) {
      html { scroll-behavior: smooth; }
    }
  </style>

  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 md:py-20 lg:px-8">
    <h1 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">Contact Us</h1>
    <p class="mt-4 text-lg leading-relaxed text-body">Get in touch with the Manchester River Cruises team.</p>

    {/* Success message — hidden by CSS until #contact-success is the :target (see the
        style block above). Static markup: perceivable without JS when the fragment is set. */}
    <div id="contact-success" class="mt-6 rounded-card bg-panel p-4 text-body ring-1 ring-black/5">
      <p class="font-medium text-ink">Thanks for getting in touch. We'll get back to you within 24 hours.</p>
    </div>

    <div class="mt-10 grid gap-10 md:grid-cols-2">
      {/* Left column — contact details */}
      <div>
        <SectionHeading as="h2">Contact details</SectionHeading>
        <div class="mt-6 space-y-5 text-body">
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-subtle">Email</h3>
            <p class="mt-1">
              <a href={`mailto:${site.email}`} class="font-medium text-primary hover:underline">{site.email}</a>
            </p>
          </div>
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-subtle">Phone</h3>
            <p class="mt-1">
              <a href={site.phoneHref} class="font-medium text-primary hover:underline">{site.phone}</a>
            </p>
          </div>
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-subtle">Address</h3>
            <address class="mt-1 not-italic">{site.addressDisplay}</address>
          </div>
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-subtle">Follow us</h3>
            <ul class="mt-1 flex flex-wrap gap-4">
              {
                social.map((s) => (
                  <li>
                    <a
                      href={s.href}
                      target="_blank"
                      rel="noopener"
                      class="font-medium text-primary hover:underline"
                      aria-label={s.label}
                    >
                      {s.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>

      {/* Right column — enquiry form (Netlify Forms; static HTML at build time) */}
      <div>
        <SectionHeading as="h2">Send us a message</SectionHeading>
        <form
          name="contact"
          method="POST"
          action="/contact?success=true#contact-success"
          data-netlify="true"
          data-netlify-honeypot="bot-field"
          class="mt-6 space-y-4"
        >
          {/* Required by Netlify Forms to identify the submission */}
          <input type="hidden" name="form-name" value="contact" />
          {/* Honeypot — hidden from humans */}
          <p class="hidden">
            <label>Don't fill this out if you're human: <input name="bot-field" /></label>
          </p>

          <div>
            <label for="name" class={fieldLabel}>Name</label>
            <input type="text" id="name" name="name" autocomplete="name" required class={inputClass} />
          </div>
          <div>
            <label for="email" class={fieldLabel}>Email</label>
            <input type="email" id="email" name="email" autocomplete="email" required class={inputClass} />
          </div>
          <div>
            <label for="phone" class={fieldLabel}>Phone</label>
            <input type="tel" id="phone" name="phone" autocomplete="tel" class={inputClass} />
          </div>
          <div>
            <label for="subject" class={fieldLabel}>Subject</label>
            <select id="subject" name="subject" class={inputClass}>
              {subjects.map((s) => <option value={s}>{s}</option>)}
            </select>
          </div>
          <div>
            <label for="message" class={fieldLabel}>Message</label>
            <textarea id="message" name="message" rows="5" required class={inputClass}></textarea>
          </div>
          <div>
            <button type="submit" class="btn btn-primary">Send message</button>
          </div>
        </form>
      </div>
    </div>

    {/* FAQ link */}
    <div class="mt-12 rounded-card bg-panel p-6 ring-1 ring-black/5 sm:flex sm:items-center sm:justify-between sm:gap-6">
      <p class="font-semibold text-ink">Looking for quick answers?</p>
      <div class="mt-4 shrink-0 sm:mt-0">
        <CTAButton href="/faq" variant="outline">Check our FAQ</CTAButton>
      </div>
    </div>
  </div>

  {/* Progressive enhancement ONLY: the message is revealed by CSS :target (above).
      Netlify's form redirect drops the URL #fragment, so if we land on ?success=true
      without it, set the hash to trigger :target. Scroll behaviour (smooth only under
      prefers-reduced-motion: no-preference) is handled in CSS, not here. */}
  <script>
    if (new URLSearchParams(window.location.search).get('success') === 'true'
        && window.location.hash !== '#contact-success') {
      window.location.hash = 'contact-success';
    }
  </script>
</BaseLayout>
