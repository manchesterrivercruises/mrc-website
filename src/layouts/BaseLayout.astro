---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { buildBreadcrumbs, type Crumb } from '../lib/breadcrumbs';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string; // og:image — path (resolved against the site) or absolute URL
  canonical?: string; // override the computed canonical URL
  ogType?: string; // og:type, e.g. "website" | "article"
  breadcrumbs?: Crumb[]; // override the auto-derived breadcrumb trail
  bookProductID?: string; // page primary product → header Book Now opens it (else the chooser)
}

const {
  title = 'Manchester River Cruises',
  description = 'Sightseeing river cruises and private hire on the Manchester Ship Canal from Salford Quays. Book direct for the best availability.',
  image = '/images/logo-colour.png', // default og:image — brand logo until real photography exists
  canonical,
  ogType = 'website',
  breadcrumbs,
  bookProductID,
} = Astro.props;

// BreadcrumbList — auto-derived from the pathname (Home > section > page) unless a
// page passes an explicit `breadcrumbs` prop. Omitted on the homepage (single item).
const crumbs = breadcrumbs ?? buildBreadcrumbs(Astro.url.pathname);
const breadcrumbSchema =
  crumbs.length > 1
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: crumbs.map((c, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: c.name,
          item: c.url,
        })),
      }
    : null;

// Canonical + absolute OG URLs. Astro.site is set in astro.config.mjs.
const siteURL = Astro.site ?? new URL('/', Astro.url);
const canonicalURL = canonical ?? new URL(Astro.url.pathname, siteURL).href;
const ogImage = new URL(image, siteURL).href;

// Site-wide business entity carrying the social profiles (schema.org sameAs).
// Emitted on every page so search engines can associate our socials site-wide.
const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${site.url}#business`,
  name: site.name,
  url: site.url,
  image: new URL('/images/logo-colour.png', siteURL).href,
  sameAs: Object.values(site.socials),
};

// Global image-error fallback: any <img data-img-fallback> that fails to load (e.g. a temp
// hotlink that 404s) swaps to the branded placeholder. One document-level capture listener
// (error doesn't bubble; capture catches it, including dynamically-created cards) + a scan for
// images that already failed before the listener attached. set:html, so no inline handler
// (CSP-safe). Placed in <head> so it's armed before body images load.
const IMG_FALLBACK_SCRIPT = `
(function () {
  var FB = '/images/gallery-placeholder.svg';
  function apply(img) {
    if (!img || img.dataset.imgFallbackApplied) return;
    img.dataset.imgFallbackApplied = '1';
    if (img.getAttribute('src') !== FB) img.src = FB;
  }
  document.addEventListener('error', function (e) {
    var t = e.target;
    if (t && t.tagName === 'IMG' && t.hasAttribute('data-img-fallback')) apply(t);
  }, true);
  function scan() {
    document.querySelectorAll('img[data-img-fallback]').forEach(function (img) {
      if (img.complete && img.naturalWidth === 0) apply(img);
    });
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', scan);
  else scan();
})();
`;

// Google Tag Manager — only rendered when GTM_CONTAINER_ID is set (build-time env var).
const gtmId = process.env.GTM_CONTAINER_ID;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* Google Tag Manager (only when GTM_CONTAINER_ID is configured) */}
    {
      gtmId && (
        <script define:vars={{ gtmId }}>
          (function (w, d, s, l, i) {
            w[l] = w[l] || [];
            w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
            var f = d.getElementsByTagName(s)[0],
              j = d.createElement(s),
              dl = l != 'dataLayer' ? '&l=' + l : '';
            j.async = true;
            j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
            f.parentNode.insertBefore(j, f);
          })(window, document, 'script', 'dataLayer', gtmId);
        </script>
      )
    }

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    {/* Open Graph */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Manchester River Cruises" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* Inter — SELF-HOSTED (@font-face in global.css). No Google Fonts request, so no
        visitor IPs leak to Google's CDN pre-consent (UK GDPR), and one fewer render-
        blocking origin. Preload the primary text weight (400) to avoid hero FOUT.
        crossorigin MUST carry the value "anonymous": browsers fetch @font-face files in
        anonymous CORS mode even for same-origin fonts, so a preload whose CORS mode
        doesn't match is treated as a *separate* resource — the font is fetched twice and
        the console warns the preload went "unused". Explicit value (not a bare attribute)
        so the mode is unambiguous and matches the font request exactly. */}
    <link
      rel="preload"
      href="/fonts/inter-latin-400-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    {/* Site-wide business entity + social profiles (sameAs) */}
    <script type="application/ld+json" is:inline set:html={JSON.stringify(businessSchema)} />

    {/* BreadcrumbList structured data (auto-derived; omitted on the homepage) */}
    {breadcrumbSchema && <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />}

    {/* Per-page head injection (extra meta, JSON-LD, preloads, etc.) */}
    <slot name="head" />

    {/* Global img-error fallback (see IMG_FALLBACK_SCRIPT). */}
    <script is:inline set:html={IMG_FALLBACK_SCRIPT} />
  </head>
  <body class="flex min-h-screen flex-col bg-page text-ink">
    {/* Google Tag Manager (noscript) */}
    {
      gtmId && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
            title="Google Tag Manager"
          />
        </noscript>
      )
    }

    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[60] focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:font-medium focus:text-white"
    >
      Skip to content
    </a>
    <Header bookProductID={bookProductID} />
    <main id="main" class="flex-grow bg-white">
      <slot />
    </main>
    <Footer />

    {/* NOTE: the Ventrata checkout loader (script + pop-up observer) is rendered ONCE by
        <Header>, so it — and the Book Now trigger — ship site-wide, making every page
        booking-capable (AGENTS rule 9, updated). Pages pass bookProductID to open their
        own product; others get the all-products chooser. `ventrata-open` styling is in
        global.css. */}
  </body>
</html>
