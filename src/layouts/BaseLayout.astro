---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { buildBreadcrumbs, type Crumb } from '../lib/breadcrumbs';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string; // og:image — path (resolved against the site) or absolute URL
  canonical?: string; // override the computed canonical URL
  ogType?: string; // og:type, e.g. "website" | "article"
  breadcrumbs?: Crumb[]; // override the auto-derived breadcrumb trail
}

const {
  title = 'Manchester River Cruises',
  description = 'Sightseeing river cruises and private hire on the Manchester Ship Canal from Salford Quays. Book direct for the best availability.',
  image = '/images/logo-colour.png', // default og:image — brand logo until real photography exists
  canonical,
  ogType = 'website',
  breadcrumbs,
} = Astro.props;

// BreadcrumbList — auto-derived from the pathname (Home > section > page) unless a
// page passes an explicit `breadcrumbs` prop. Omitted on the homepage (single item).
const crumbs = breadcrumbs ?? buildBreadcrumbs(Astro.url.pathname);
const breadcrumbSchema =
  crumbs.length > 1
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: crumbs.map((c, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: c.name,
          item: c.url,
        })),
      }
    : null;

// Canonical + absolute OG URLs. Astro.site is set in astro.config.mjs.
const siteURL = Astro.site ?? new URL('/', Astro.url);
const canonicalURL = canonical ?? new URL(Astro.url.pathname, siteURL).href;
const ogImage = new URL(image, siteURL).href;

// Site-wide business entity carrying the social profiles (schema.org sameAs).
// Emitted on every page so search engines can associate our socials site-wide.
const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${site.url}#business`,
  name: site.name,
  url: site.url,
  image: new URL('/images/logo-colour.png', siteURL).href,
  sameAs: Object.values(site.socials),
};

// Google Tag Manager — only rendered when GTM_CONTAINER_ID is set (build-time env var).
const gtmId = process.env.GTM_CONTAINER_ID;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* Google Tag Manager (only when GTM_CONTAINER_ID is configured) */}
    {
      gtmId && (
        <script define:vars={{ gtmId }}>
          (function (w, d, s, l, i) {
            w[l] = w[l] || [];
            w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
            var f = d.getElementsByTagName(s)[0],
              j = d.createElement(s),
              dl = l != 'dataLayer' ? '&l=' + l : '';
            j.async = true;
            j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
            f.parentNode.insertBefore(j, f);
          })(window, document, 'script', 'dataLayer', gtmId);
        </script>
      )
    }

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    {/* Open Graph */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Manchester River Cruises" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* Inter (Google Fonts) — backs the --font-sans design token */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    {/* Site-wide business entity + social profiles (sameAs) */}
    <script type="application/ld+json" is:inline set:html={JSON.stringify(businessSchema)} />

    {/* BreadcrumbList structured data (auto-derived; omitted on the homepage) */}
    {breadcrumbSchema && <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />}

    {/* Per-page head injection (extra meta, JSON-LD, preloads, etc.) */}
    <slot name="head" />
  </head>
  <body class="flex min-h-screen flex-col bg-page text-ink">
    {/* Google Tag Manager (noscript) */}
    {
      gtmId && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
            title="Google Tag Manager"
          />
        </noscript>
      )
    }

    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[60] focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:font-medium focus:text-white"
    >
      Skip to content
    </a>
    <Header />
    <main id="main" class="flex-grow bg-white">
      <slot />
    </main>
    <Footer />

    {/* Ventrata checkout pop-up: let the widget own the screen (global — affects every
        page with a widget: City River Tour, event pages, ferry pages). Toggles the
        `ventrata-open` class on <html>; the styling lives in global.css. */}
    <script>
      // Ventrata checkout pop-up: let the widget own the screen. Toggles `ventrata-open`
      // on <html> (styling in global.css). Detection is IDENTITY-based, not size-based:
      // on the live build the pop-up is a centred panel ~80% wide with page gutters, so
      // the old 90%×70% size thresholds never matched and the chrome stayed visible.
      (() => {
        const root = document.documentElement;
        const KEY = 'ventrata-open';
        const body = document.body;
        if (!body) return;

        // Body children present at load — anything added later is third-party (the pop-up).
        // Our own trigger buttons ([ventrata-checkout]) and embedded widgets live deep in
        // the page, never as NEW body children, so they are excluded automatically.
        const initial = new Set(Array.from(body.children));

        // Identity: does the element or its subtree carry a ventrata/checkout id, class,
        // or attribute name?
        function looksVentrata(el: Element): boolean {
          const hit = (n: Element) => {
            if (!n || n.nodeType !== 1) return false;
            if (/ventrata|checkout/i.test(n.id || '')) return true;
            const c = typeof n.className === 'string' ? n.className : '';
            if (/ventrata|checkout/i.test(c)) return true;
            const at = n.attributes;
            if (at) for (let i = 0; i < at.length; i++) if (/ventrata|checkout/i.test(at[i].name)) return true;
            return false;
          };
          if (hit(el)) return true;
          const all = el.querySelectorAll ? el.querySelectorAll('*') : [];
          for (let i = 0; i < all.length; i++) if (hit(all[i])) return true;
          return false;
        }

        function shown(el: Element): boolean {
          const cs = getComputedStyle(el);
          if (cs.display === 'none' || cs.visibility === 'hidden') return false;
          return el.getBoundingClientRect().width > 0;
        }

        // The pop-up = a visible, post-load direct body child. Prefer one carrying ventrata
        // identity; during a trigger session accept ANY new visible body child (no size
        // threshold) so the narrow centred panel still registers.
        function overlayPresent(): boolean {
          const kids = body.children;
          let fallback = false;
          for (let i = 0; i < kids.length; i++) {
            const el = kids[i];
            if (initial.has(el) || !shown(el)) continue;
            if (looksVentrata(el)) return true;
            if (armed) fallback = true;
          }
          return fallback;
        }

        let armed = false; // a checkout opened via our trigger
        let saw = false; // the pop-up DOM has appeared this session
        let failsafe = 0;

        function evaluate() {
          const present = overlayPresent();
          if (present) saw = true;
          if (armed && saw && !present) { armed = false; saw = false; } // appeared then closed
          root.classList.toggle(KEY, armed || present);
        }

        let raf = 0;
        function schedule() {
          if (!raf) raf = requestAnimationFrame(() => { raf = 0; evaluate(); });
        }

        // (1) TRIGGER — a click on any [ventrata-checkout] element opens immediately, before
        //     the widget injects its DOM, so the header/CTA hide with no flicker. Delegated
        //     + capture so it also covers trigger buttons wired in later (step 6/9).
        document.addEventListener('click', (e) => {
          const t = e.target as Element | null;
          if (t && t.closest && t.closest('[ventrata-checkout]')) {
            armed = true;
            saw = false;
            root.classList.add(KEY);
            clearTimeout(failsafe);
            // If the pop-up never actually opens, disarm so the chrome isn't hidden forever.
            failsafe = window.setTimeout(() => { if (armed && !saw) { armed = false; evaluate(); } }, 5000);
          }
        }, true);

        // (2) CLOSE (and any non-trigger auto-open, e.g. ?openWidget=true) — watch the body
        //     for the pop-up DOM being added/removed. No size thresholds.
        new MutationObserver(schedule).observe(body, {
          childList: true,
          subtree: true,
          attributes: true,
          attributeFilter: ['style', 'class', 'hidden'],
        });

        evaluate();
      })();
    </script>
  </body>
</html>
